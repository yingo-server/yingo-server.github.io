<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>深时 · 极简弹窗倒计时</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
            -webkit-touch-callout: none;
        }

        html, body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            position: fixed;
            top: 0;
            left: 0;
            background: #000000;
            touch-action: none;
            overscroll-behavior: none;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DigitalCustom', 'Segoe UI', monospace, system-ui;
            background: #000000;
            color: #ffffff;
            transition: filter 0.05s linear;
        }

        body.invert-flash {
            filter: invert(1);
        }

        @font-face {
            font-family: 'DigitalCustom';
            src: url('data:font/ttf;base64,') format('opentype');
            font-weight: normal;
            font-style: normal;
            font-display: swap;
        }

        /* 时钟容器 — 将进行防烧屏像素偏移 */
        .clock-container {
            width: 90%;
            max-width: 900px;
            margin: 0 auto;
            padding: 1.5rem;
            background: transparent;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            pointer-events: none;
            z-index: 2;
            will-change: transform;
            transition: transform 0.2s ease-out;
        }

        .date-row, .time-row, .week-row {
            width: 100%;
            text-align: center;
            line-height: 1.2;
        }
        .date-row {
            font-family: 'DigitalCustom', monospace;
            font-size: clamp(1.8rem, 8vw, 4rem);
            margin-bottom: 0.25em;
            text-shadow: 0 0 8px rgba(255,255,255,0.3);
            white-space: nowrap;
        }
        .time-row {
            font-family: 'DigitalCustom', monospace;
            font-size: clamp(3.2rem, 14vw, 9rem);
            font-weight: 700;
            margin: 0.1em 0;
            text-shadow: 0 0 12px rgba(0,200,255,0.5);
            white-space: nowrap;
        }
        .week-row {
            font-family: 'DigitalCustom', monospace;
            font-size: clamp(1.2rem, 5vw, 2.6rem);
            opacity: 0.85;
            text-transform: uppercase;
            white-space: nowrap;
        }
        @media (max-width: 480px) {
            .clock-container { width: 95%; padding: 1rem; }
            .date-row { font-size: clamp(1.4rem, 7vw, 2.5rem); }
            .time-row { font-size: clamp(2.2rem, 12vw, 5.5rem); }
        }
        @media (orientation: landscape) and (max-height: 500px) {
            .clock-container { padding: 0.8rem; }
            .date-row { font-size: clamp(1.2rem, 6vh, 2.6rem); }
            .time-row { font-size: clamp(2rem, 12vh, 6rem); }
        }

        /* 极简弹窗 (纯黑·图标按钮) */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.96);
            backdrop-filter: blur(8px);
            z-index: 1000;
            display: flex;
            justify-content: center;
            align-items: center;
            visibility: hidden;
            opacity: 0;
            transition: opacity 0.2s ease, visibility 0.2s;
        }
        .modal-overlay.active {
            visibility: visible;
            opacity: 1;
        }
        .modal-card {
            width: 85%;
            max-width: 380px;
            background: #0a0a0a;
            border-radius: 2.5rem;
            padding: 2rem 1.5rem;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .modal-icon {
            font-size: 2rem;
            color: #ccc;
            margin-bottom: 1.5rem;
        }
        .time-input-group {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 2rem;
        }
        .input-unit {
            flex: 1;
            text-align: center;
        }
        .input-unit label {
            display: block;
            font-size: 0.7rem;
            text-transform: uppercase;
            color: #888;
            margin-bottom: 0.5rem;
            letter-spacing: 1px;
        }
        .input-unit input {
            width: 100%;
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 1.5rem;
            padding: 0.8rem 0;
            text-align: center;
            font-family: 'DigitalCustom', monospace;
            font-size: 1.8rem;
            color: #fff;
            outline: none;
        }
        .input-unit input:focus {
            border-color: #ffaa44;
            box-shadow: 0 0 8px rgba(255,170,68,0.3);
        }
        .input-unit input[type=number]::-webkit-inner-spin-button,
        .input-unit input[type=number]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        .input-unit input[type=number] {
            -moz-appearance: textfield;
        }
        .modal-buttons {
            display: flex;
            gap: 1rem;
            margin-top: 0.5rem;
        }
        .modal-btn-icon {
            flex: 1;
            background: #1a1a1a;
            border: none;
            border-radius: 3rem;
            padding: 0.8rem 0;
            font-size: 1.5rem;
            color: #ddd;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .modal-btn-icon.primary {
            background: #2c5a2e;
            color: white;
        }
        .modal-btn-icon.primary:active {
            background: #1e401f;
            transform: scale(0.96);
        }
        .modal-btn-icon.secondary:active {
            background: #2a2a2a;
            transform: scale(0.96);
        }
        .interact-hint {
            position: absolute;
            bottom: 20px;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 0.6rem;
            color: #555;
            pointer-events: none;
        }

        /* 沙漏图标 — 可点击 */
        .hourglass-icon {
            position: fixed;
            bottom: 24px;
            left: 24px;
            font-size: 1.5rem;
            color: rgba(255,255,200,0.8);
            text-shadow: 0 0 6px rgba(0,255,255,0.4);
            z-index: 60;
            cursor: pointer;
            transition: 0.2s;
            pointer-events: auto;
            background: transparent;
            padding: 6px;
            border-radius: 50%;
        }
        .hourglass-icon:active {
            transform: scale(0.92);
            opacity: 0.7;
        }
        .hourglass-icon.active {
            text-shadow: 0 0 12px #ffaa44;
        }
    </style>
</head>
<body>

<div class="clock-container" id="clockContainer">
    <div class="date-row" id="dateDisplay">加载中...</div>
    <div class="time-row" id="timeDisplay">--:--:--</div>
    <div class="week-row" id="weekDisplay">———</div>
</div>

<div id="timeModal" class="modal-overlay">
    <div class="modal-card">
        <div class="modal-icon"><i class="fa-regular fa-clock"></i></div>
        <div class="time-input-group">
            <div class="input-unit">
                <label>时</label>
                <input type="number" id="hoursInput" min="0" max="99" value="0" step="1">
            </div>
            <div class="input-unit">
                <label>分</label>
                <input type="number" id="minutesInput" min="0" max="59" value="0" step="1">
            </div>
            <div class="input-unit">
                <label>秒</label>
                <input type="number" id="secondsInput" min="0" max="59" value="0" step="1">
            </div>
        </div>
        <div class="modal-buttons">
            <button class="modal-btn-icon secondary" id="cancelBtn"><i class="fa-regular fa-circle-xmark"></i></button>
            <button class="modal-btn-icon primary" id="saveBtn"><i class="fa-regular fa-circle-check"></i></button>
        </div>
        <div class="interact-hint">⏎ 点击沙漏 · 累加时间</div>
    </div>
</div>

<div id="hourglass" class="hourglass-icon"><i class="fa-regular fa-hourglass-half"></i></div>

<script>
    // ======================= 1. 首次触摸全屏 (仅执行一次) =======================
    let fullscreenTriggered = false;
    function requestFullscreen() {
        const elem = document.documentElement;
        const method = elem.requestFullscreen || elem.webkitRequestFullscreen || elem.msRequestFullscreen;
        if (method) method.call(elem);
    }
    function onFirstTouch() {
        if (!fullscreenTriggered) {
            fullscreenTriggered = true;
            requestFullscreen();
            document.body.removeEventListener('touchstart', onFirstTouch);
            document.body.removeEventListener('click', onFirstTouch);
        }
    }
    // 监听第一次触摸/点击事件 (仅一次)
    document.body.addEventListener('touchstart', onFirstTouch, { once: false });
    document.body.addEventListener('click', onFirstTouch, { once: false });
    // 确保只触发一次，用标志控制，且不会多次添加

    // ======================= 2. 定时像素偏移 (防烧屏，科学研究值：每120秒偏移1-2px，范围[-1,1]px) =======================
    const clockContainer = document.getElementById('clockContainer');
    let shiftInterval = null;
    let currentX = 0, currentY = 0;
    function applyPixelShift() {
        // 生成随机偏移量：-1, 0, 1 像素，大部分设备肉眼无感知但足以防止静态像素老化
        const deltaX = (Math.floor(Math.random() * 3) - 1); // -1,0,1
        const deltaY = (Math.floor(Math.random() * 3) - 1);
        // 平滑移动，避免跳跃感
        currentX += deltaX;
        currentY += deltaY;
        // 限制最大偏移不超过 ±3 像素，防止内容跑出视野
        currentX = Math.min(3, Math.max(-3, currentX));
        currentY = Math.min(3, Math.max(-3, currentY));
        clockContainer.style.transform = `translate(${currentX}px, ${currentY}px)`;
    }
    // 启动防烧屏定时器：间隔 90 秒 (常见OLED防烧屏策略)
    function startPixelShifting() {
        if (shiftInterval) clearInterval(shiftInterval);
        shiftInterval = setInterval(applyPixelShift, 90000); // 90秒
        // 页面刚加载也立刻偏移一次，避免长时间完全静止
        setTimeout(applyPixelShift, 1000);
    }
    startPixelShifting();
    // 可选：页面可见性变化时可调整定时器，但无关紧要

    // ======================= 3. 数字时钟 =======================
    function updateClockUI() {
        const now = new Date();
        const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        const weekdays = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
        const timeStr = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}:${String(now.getSeconds()).padStart(2,'0')}`;
        const dateStr = `${months[now.getMonth()]} ${now.getDate()}, ${now.getFullYear()}`;
        document.getElementById('timeDisplay').innerText = timeStr;
        document.getElementById('dateDisplay').innerText = dateStr;
        document.getElementById('weekDisplay').innerText = weekdays[now.getDay()];
    }
    updateClockUI();
    setInterval(updateClockUI, 1000);

    // ======================= 4. 提示音模块 =======================
    let audioCtx = null;
    function initAudio() {
        if (audioCtx) return;
        try {
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            const buffer = audioCtx.createBuffer(1, 1, 22050);
            const source = audioCtx.createBufferSource();
            source.buffer = buffer;
            source.connect(audioCtx.destination);
            source.start();
        } catch(e) {}
    }
    function playBeep() {
        if (!audioCtx) return;
        const resumePlay = () => {
            if (audioCtx.state === 'suspended') audioCtx.resume().then(() => actuallyBeep()).catch(()=>{});
            else if (audioCtx.state === 'running') actuallyBeep();
        };
        function actuallyBeep() {
            if (!audioCtx) return;
            const now = audioCtx.currentTime;
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.type = 'sine';
            osc.frequency.value = 880;
            gain.gain.value = 0.12;
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.start();
            gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.12);
            osc.stop(now + 0.12);
        }
        resumePlay();
    }
    function playBeepMultiple(times, intervalMs = 180) {
        let count = 0;
        function next() {
            if (count >= times) return;
            playBeep();
            count++;
            setTimeout(next, intervalMs);
        }
        next();
    }

    // ======================= 5. 倒计时核心 (累加+反色+音效) =======================
    let remainingSeconds = 0;
    let countdownInterval = null;
    let isCountdownRunning = false;
    let countdownBaseTotal = 0;
    let reminderFlags = { half: false, threeQuarter: false, tenMin: false, threeMin: false, lastThreeMinFlag: false, ended: false };
    function fullResetReminderFlags() {
        reminderFlags = { half: false, threeQuarter: false, tenMin: false, threeMin: false, lastThreeMinFlag: false, ended: false };
    }

    function flashInvertWithBeep(count, onMs, offMs, finalCallback) {
        let i = 0;
        const body = document.body;
        function step() {
            if (i >= count) {
                if (finalCallback) finalCallback();
                return;
            }
            body.classList.add('invert-flash');
            playBeep();
            setTimeout(() => {
                body.classList.remove('invert-flash');
                i++;
                if (i < count) setTimeout(step, offMs);
                else if (finalCallback) finalCallback();
            }, onMs);
        }
        step();
    }

    function checkReminders(remainingSec, initialTotal) {
        if (remainingSec <= 0) {
            if (!reminderFlags.ended) {
                reminderFlags.ended = true;
                let endCount = 0;
                const endInterval = setInterval(() => {
                    document.body.classList.add('invert-flash');
                    playBeep();
                    setTimeout(() => document.body.classList.remove('invert-flash'), 400);
                    endCount++;
                    if (endCount >= 5) clearInterval(endInterval);
                }, 500);
                if (countdownInterval) clearInterval(countdownInterval);
                isCountdownRunning = false;
                countdownInterval = null;
                document.getElementById('hourglass').style.opacity = '0.5';
                document.getElementById('hourglass').classList.remove('active');
            }
            return;
        }
        if (initialTotal <= 0) return;
        const elapsed = initialTotal - remainingSec;
        const percent = elapsed / initialTotal;
        if (!reminderFlags.half && percent >= 0.5) {
            reminderFlags.half = true;
            flashInvertWithBeep(1, 1000, 1000);
        }
        if (!reminderFlags.threeQuarter && percent >= 0.75) {
            reminderFlags.threeQuarter = true;
            flashInvertWithBeep(2, 1000, 1000);
        }
        const isLong = initialTotal > 15 * 60;
        if (isLong && !reminderFlags.tenMin && remainingSec <= (initialTotal - 10*60) && remainingSec > (initialTotal - 10*60 - 2)) {
            reminderFlags.tenMin = true;
            flashInvertWithBeep(3, 1000, 1000);
        }
        if (!isLong && !reminderFlags.threeMin && remainingSec <= (initialTotal - 3*60) && remainingSec > (initialTotal - 3*60 - 2)) {
            reminderFlags.threeMin = true;
            flashInvertWithBeep(3, 1000, 1000);
        }
        if (!reminderFlags.lastThreeMinFlag && initialTotal > 180 && remainingSec === 180) {
            reminderFlags.lastThreeMinFlag = true;
            flashInvertWithBeep(4, 1000, 1000);
        }
    }

    function stopCountdown(resetData = false) {
        if (countdownInterval) clearInterval(countdownInterval);
        countdownInterval = null;
        isCountdownRunning = false;
        if (resetData) { remainingSeconds = 0; countdownBaseTotal = 0; }
        const hg = document.getElementById('hourglass');
        hg.style.opacity = '0.5';
        hg.classList.remove('active');
    }

    function startCountdown() {
        if (countdownInterval) clearInterval(countdownInterval);
        if (remainingSeconds <= 0) {
            isCountdownRunning = false;
            document.getElementById('hourglass').style.opacity = '0.5';
            document.getElementById('hourglass').classList.remove('active');
            return;
        }
        isCountdownRunning = true;
        const hg = document.getElementById('hourglass');
        hg.style.opacity = '1';
        hg.classList.add('active');
        countdownInterval = setInterval(() => {
            if (remainingSeconds <= 0) {
                clearInterval(countdownInterval);
                countdownInterval = null;
                isCountdownRunning = false;
                checkReminders(0, countdownBaseTotal);
                remainingSeconds = 0;
                const hg2 = document.getElementById('hourglass');
                hg2.style.opacity = '0.5';
                hg2.classList.remove('active');
                return;
            }
            remainingSeconds--;
            checkReminders(remainingSeconds, countdownBaseTotal);
        }, 1000);
    }

    function addTime(hours, minutes, seconds) {
        let addSec = hours * 3600 + minutes * 60 + seconds;
        if (addSec === 0) return false;
        const wasRunning = isCountdownRunning;
        const wasZero = (remainingSeconds === 0);
        const oldTotal = countdownBaseTotal;
        const oldRemaining = remainingSeconds;
        remainingSeconds += addSec;
        if (wasZero) {
            countdownBaseTotal = remainingSeconds;
            fullResetReminderFlags();
        } else {
            const elapsed = oldTotal - oldRemaining;
            const newTotal = oldTotal + addSec;
            countdownBaseTotal = newTotal;
            const wasHalf = reminderFlags.half;
            const wasThreeQuarter = reminderFlags.threeQuarter;
            fullResetReminderFlags();
            reminderFlags.half = wasHalf;
            reminderFlags.threeQuarter = wasThreeQuarter;
            reminderFlags.ended = false;
        }
        if (!wasRunning && remainingSeconds > 0) startCountdown();
        else if (wasRunning && countdownInterval) checkReminders(remainingSeconds, countdownBaseTotal);
        const hg = document.getElementById('hourglass');
        if (remainingSeconds > 0 && isCountdownRunning) {
            hg.style.opacity = '1';
            hg.classList.add('active');
        } else if (remainingSeconds > 0 && !isCountdownRunning) startCountdown();
        else { hg.style.opacity = '0.5'; hg.classList.remove('active'); }
        return true;
    }

    // ======================= 6. 弹窗交互 =======================
    const modal = document.getElementById('timeModal');
    const hoursInput = document.getElementById('hoursInput');
    const minutesInput = document.getElementById('minutesInput');
    const secondsInput = document.getElementById('secondsInput');
    const saveBtn = document.getElementById('saveBtn');
    const cancelBtn = document.getElementById('cancelBtn');
    const hourglassIcon = document.getElementById('hourglass');

    function openModal() {
        initAudio();
        if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
        hoursInput.value = 0;
        minutesInput.value = 0;
        secondsInput.value = 0;
        modal.classList.add('active');
    }
    function closeModal() { modal.classList.remove('active'); }
    function saveAndAccumulate() {
        initAudio();
        if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
        let hrs = parseInt(hoursInput.value,10) || 0;
        let mins = parseInt(minutesInput.value,10) || 0;
        let secs = parseInt(secondsInput.value,10) || 0;
        hrs = Math.min(99, Math.max(0, hrs));
        mins = Math.min(59, Math.max(0, mins));
        secs = Math.min(59, Math.max(0, secs));
        if (hrs===0 && mins===0 && secs===0) { closeModal(); return; }
        addTime(hrs, mins, secs);
        closeModal();
    }
    saveBtn.addEventListener('click', saveAndAccumulate);
    cancelBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    function clampMinSec(inp, max) { let v = parseInt(inp.value,10); if (isNaN(v)) v=0; if(v>max) inp.value=max; if(v<0) inp.value=0; }
    minutesInput.addEventListener('change',()=>clampMinSec(minutesInput,59));
    secondsInput.addEventListener('change',()=>clampMinSec(secondsInput,59));
    hoursInput.addEventListener('change',()=>{ let v=parseInt(hoursInput.value,10); if(isNaN(v)) v=0; if(v>99) hoursInput.value=99; if(v<0) hoursInput.value=0; });
    hourglassIcon.addEventListener('click', (e) => { e.stopPropagation(); openModal(); });

    // 全局滚动阻止
    function globalTouchMoveBlocker(e) {
        if (modal.classList.contains('active') && (e.target.tagName === 'INPUT' || e.target.closest('.input-unit'))) return;
        e.preventDefault();
    }
    document.body.addEventListener('touchmove', globalTouchMoveBlocker, { passive: false });
    document.body.addEventListener('wheel', (e) => e.preventDefault(), { passive: false });
    document.addEventListener('contextmenu', e => e.preventDefault());

    // 沙漏状态动画
    setInterval(() => {
        const icon = document.getElementById('hourglass');
        if (isCountdownRunning && remainingSeconds > 0) {
            icon.style.opacity = '1';
            icon.classList.add('active');
        } else {
            icon.style.opacity = '0.5';
            icon.classList.remove('active');
        }
    }, 300);

    // 初始状态
    remainingSeconds = 0;
    countdownBaseTotal = 0;
    isCountdownRunning = false;
    fullResetReminderFlags();
    document.getElementById('hourglass').style.opacity = '0.5';
    document.getElementById('hourglass').classList.remove('active');

    console.log('✅ 已启用: 首次触摸全屏 + 每90秒像素偏移(±1px)防烧屏');
</script>
</body>
</html>