    { "id": "17", "x": -24, "y": 12, "z": -50, "width": 5, "depth": 5, "height": 1, "tooltip": "", "tooltip_en": "" },
    { "id": "18", "x": -32, "y": 13, "z": -50, "width": 5, "depth": 5, "height": 1, "tooltip": "", "tooltip_en": "" },
