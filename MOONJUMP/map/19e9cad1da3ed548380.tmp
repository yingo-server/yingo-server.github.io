    { "id": "21", "x": -8, "y": 15, "z": -58, "width": 6, "depth": 6, "height": 1, "tooltip": "没人会等你。", "tooltip_en": "No one waits." },
    { "id": "22", "x": 0, "y": 15.5, "z": -58, "width": 5, "depth": 5, "height": 1, "tooltip": "", "tooltip_en": "" },
