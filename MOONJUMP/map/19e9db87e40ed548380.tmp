{
  "ver": "3.0",
  "name": "无知",
  "startPosition": { "x": 0, "y": 2, "z": 0 },
  "platforms": [
    { "id": "1", "x": 0, "y": 0.5, "z": 0, "width": 8, "depth": 8, "height": 1, "type": 1, "tooltip": "", "tooltip_en": "" },
    { "id": "2", "x": 10, "y": 1.5, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "3", "x": 20, "y": 2, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "4", "x": 30, "y": 2.5, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "希望迟迟不来，苦死了等待的人。", "tooltip_en": "Hope deferred makes the waiting heart sick." },
    { "id": "5", "x": 40, "y": 3, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "6", "x": 40, "y": 3, "z": -10, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "与未知缠斗过久，自身亦成为未知。", "tooltip_en": "He who fights with the unknown becomes unknown himself." },
    { "id": "7", "x": 30, "y": 3.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "8", "x": 20, "y": 4, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "路是假的，远方是一条没有归途的路。", "tooltip_en": "The road is false, the distance is a road with no return." },
    { "id": "9", "x": 10, "y": 4.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "10", "x": 0, "y": 5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "唯有孤独永恒。", "tooltip_en": "Only solitude is eternal." },
    { "id": "11", "x": -10, "y": 5.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "12", "x": -20, "y": 6, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "13", "x": -30, "y": 6.5, "z": -10, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "生命没有意义，活着也没有目的。", "tooltip_en": "Life has no meaning, existence has no purpose." },
    { "id": "14", "x": -40, "y": 7, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "15", "x": -40, "y": 7, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "此生的欢乐不是生命本身的，而是向更高处上升前的恐惧。", "tooltip_en": "The joy of this life is not life itself, but the fear before rising higher." },
    { "id": "16", "x": -30, "y": 7.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "17", "x": -20, "y": 8, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "18", "x": -10, "y": 8.5, "z": -20, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "每个人都是沉默的，孤独的。", "tooltip_en": "Everyone is silent, everyone is alone." },
    { "id": "19", "x": 0, "y": 9, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "20", "x": 10, "y": 9.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "21", "x": 20, "y": 10, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "我们称之为路的，其实不过是彷徨。", "tooltip_en": "What we call the road is only hesitation." },
    { "id": "22", "x": 30, "y": 10.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "23", "x": 30, "y": 11, "z": -30, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "24", "x": 20, "y": 11.5, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "无论转向何方，总有黑浪迎面打来。", "tooltip_en": "Wherever we turn, dark waves crash upon us." },
    { "id": "25", "x": 10, "y": 12, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "26", "x": 0, "y": 12.5, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "27", "x": -10, "y": 13, "z": -30, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "昨天，路开始了。也许是今天，不知道。", "tooltip_en": "Yesterday, the road began. Maybe today, I don't know." },
    { "id": "28", "x": -10, "y": 13.5, "z": -40, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "29", "x": -10, "y": 14, "z": -50, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "人只有自己知道自己能做什么。但只有到极限才知道。", "tooltip_en": "One only knows what one can do. But only at the limit." },
    { "id": "30", "x": -10, "y": 14.5, "z": -60, "width": 10, "depth": 10, "height": 1, "type": 3, "tooltip": "无知不是福，是开始。", "tooltip_en": "Ignorance is not bliss, it's the beginning." }
  ],
  "walls": [
    { "id": "31", "x": 15, "y": 2, "z": -4, "width": 2, "height": 3, "depth": 0.5 },
    { "id": "32", "x": 35, "y": 2.5, "z": -4, "width": 2, "height": 3, "depth": 0.5 },
