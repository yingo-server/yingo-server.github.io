{
  "ver": "3.0",
  "name": "愤怒",
  "startPosition": { "x": 0, "y": 2, "z": 0 },
  "platforms": [
    { "id": "1", "x": 0, "y": 0.5, "z": 0, "width": 8, "depth": 8, "height": 1, "type": 1, "tooltip": "", "tooltip_en": "" },
    { "id": "2", "x": 10, "y": 1.5, "z": 0, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "3", "x": 20, "y": 2, "z": 0, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "勇者愤怒，抽刃向更强者；怯者愤怒，却抽刃向更弱者。", "tooltip_en": "The brave aim their anger at the stronger; the coward aims at the weaker." },
    { "id": "4", "x": 30, "y": 3, "z": 0, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "5", "x": 30, "y": 3.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "在黑暗的时代不反抗，就意味着同谋。", "tooltip_en": "In dark times, not to resist is to be complicit." },
    { "id": "6", "x": 20, "y": 4, "z": -10, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "7", "x": 10, "y": 4.5, "z": -10, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "8", "x": 0, "y": 5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "心脏是一座有两间卧室的房子，一间住着痛苦，另一间住着欢乐，不能笑得太响。", "tooltip_en": "The heart is a house with two rooms, one for pain and one for joy, and you cannot laugh too loud." },
    { "id": "9", "x": -10, "y": 5.5, "z": -10, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "10", "x": -20, "y": 6, "z": -10, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "11", "x": -20, "y": [5, 9], "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "speed": 0.35, "tooltip": "看见的，正是因为想看见。", "tooltip_en": "What is seen is because one wants to see." },
    { "id": "12", "x": -10, "y": 7, "z": -20, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "13", "x": 0, "y": 7.5, "z": -20, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "14", "x": 10, "y": 8, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "对生活的要求太高了，世界吐了出来。", "tooltip_en": "Demands on life were too high; the world spat out." },
    { "id": "15", "x": 20, "y": 8.5, "z": -20, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "16", "x": 30, "y": 9, "z": -20, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "17", "x": 30, "y": [8, 12], "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "speed": 0.35, "tooltip": "所有的喜悦都掺杂着不祥的预感。", "tooltip_en": "Every joy is tinged with a foreboding." },
    { "id": "18", "x": 20, "y": 10, "z": -30, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "19", "x": 10, "y": 10.5, "z": -30, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "20", "x": 0, "y": 11, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "不存在没有真实的人生，真实恐怕就是指人生本身吧。", "tooltip_en": "There is no life without truth; truth is probably life itself." },
    { "id": "21", "x": -10, "y": 11.5, "z": -30, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "22", "x": -20, "y": 12, "z": -30, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "23", "x": -20, "y": [11, 15], "z": -40, "width": 7, "depth": 7, "height": 1, "type": 0, "speed": 0.35, "tooltip": "人生最残酷的事，是面对偌大的世界，成了赤手空拳的俯首就擒者。", "tooltip_en": "The cruelest thing is to face this vast world empty-handed, a captive already." },
    { "id": "24", "x": -10, "y": 13, "z": -40, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "25", "x": 0, "y": 13.5, "z": -40, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "26", "x": 10, "y": 14, "z": -40, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "在愤怒的尽头，是沉默。", "tooltip_en": "At the end of anger, silence." },
    { "id": "27", "x": 20, "y": 14.5, "z": -40, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "28", "x": 30, "y": 15, "z": -40, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "29", "x": 30, "y": 15.5, "z": -50, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "黑暗不能驱散黑暗，只有光可以。", "tooltip_en": "Darkness cannot drive out darkness; only light can." },
    { "id": "30", "x": 20, "y": 16, "z": -50, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "31", "x": 10, "y": 16.5, "z": -50, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "愤怒之后，路还在。", "tooltip_en": "After anger, the road remains." },
    { "id": "32", "x": 0, "y": 17, "z": -50, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "33", "x": -10, "y": 17.5, "z": -50, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "34", "x": -10, "y": 18, "z": -60, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "愿意的话，可以停止；愿意的话，也可以继续。", "tooltip_en": "If you wish, you can stop; if you wish, you can continue." },
    { "id": "35", "x": -10, "y": 18.5, "z": -70, "width": 10, "depth": 10, "height": 1, "type": 3, "tooltip": "愤怒之后，是接受。", "tooltip_en": "After anger, acceptance." }
  ],
