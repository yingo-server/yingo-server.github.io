{
  "ver": "3.0",
  "name": "否定",
  "startPosition": { "x": 0, "y": 2, "z": 0 },
  "platforms": [
    { "id": "1", "x": 0, "y": 0.5, "z": 0, "width": 8, "depth": 8, "height": 1, "type": 1, "tooltip": "", "tooltip_en": "" },
    { "id": "2", "x": -10, "y": 1, "z": -8, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "3", "x": 12, "y": 1.5, "z": -6, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "4", "x": -20, "y": 2, "z": -15, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "5", "x": 5, "y": 2.5, "z": -18, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "6", "x": 22, "y": 3, "z": -12, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "7", "x": -15, "y": 3.5, "z": -25, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "活着不是胜利，活得像个人才是。", "tooltip_en": "Living is not victory, living like a human being is." },
    { "id": "8", "x": 0, "y": 4, "z": -22, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "9", "x": 28, "y": 4.5, "z": -20, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "10", "x": -28, "y": 5, "z": -32, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "11", "x": 10, "y": 5.5, "z": -30, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "12", "x": -8, "y": 6, "z": -35, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "这里没有退路。", "tooltip_en": "There is no way back here." },
    { "id": "13", "x": 18, "y": 6.5, "z": -28, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "14", "x": -18, "y": 7, "z": -42, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "15", "x": 30, "y": 7.5, "z": -38, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "我肮脏了一辈子，死的时候我想干净一点。", "tooltip_en": "I have been dirty all my life, I want to be clean when I die." },
    { "id": "16", "x": 5, "y": 8, "z": -45, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "17", "x": -22, "y": 8.5, "z": -48, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "18", "x": 25, "y": 9, "z": -44, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "19", "x": -12, "y": 9.5, "z": -55, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "这场战只能我一个人打。", "tooltip_en": "This battle can only be fought by me alone." },
    { "id": "20", "x": 15, "y": 10, "z": -50, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "21", "x": -30, "y": 10.5, "z": -60, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "22", "x": 0, "y": 11, "z": -58, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "23", "x": 22, "y": 11.5, "z": -62, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "路只有一条，向前或停下。", "tooltip_en": "There is only one road, forward or stop." },
    { "id": "24", "x": -8, "y": 12, "z": -68, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "25", "x": 18, "y": 12.5, "z": -70, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "26", "x": -25, "y": 13, "z": -65, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "27", "x": 8, "y": 13.5, "z": -78, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "没有人会去质疑一份希望的重量。", "tooltip_en": "No one questions the weight of a hope." },
    { "id": "28", "x": -15, "y": 14, "z": -80, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "29", "x": 28, "y": 14.5, "z": -75, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "30", "x": -5, "y": 15, "z": -88, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "31", "x": 12, "y": 15.5, "z": -85, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "碎过的镜子，补好也不是新的。", "tooltip_en": "A broken mirror, even mended, is not new." },
    { "id": "32", "x": -22, "y": 16, "z": -92, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "33", "x": 20, "y": 16.5, "z": -95, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "34", "x": -30, "y": 17, "z": -90, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "35", "x": 0, "y": 17.5, "z": -102, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "希望让人在绝望中继续受苦。", "tooltip_en": "Hope makes people continue to suffer in despair." },
    { "id": "36", "x": -12, "y": 18, "z": -105, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "37", "x": 18, "y": 18.5, "z": -100, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "38", "x": -20, "y": 19, "z": -112, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "39", "x": 8, "y": 19.5, "z": -115, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "这世上没有绝望的处境，只有对处境绝望的人。", "tooltip_en": "There is no desperate situation in this world, only people who are desperate about the situation." },
    { "id": "40", "x": -8, "y": 20, "z": -120, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "41", "x": 15, "y": 20.5, "z": -118, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "42", "x": -25, "y": 21, "z": -125, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "43", "x": 5, "y": 21.5, "z": -130, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "做过的决定永不回想，走过的路永不回看。", "tooltip_en": "Never look back on decisions made, never look back on roads traveled." },
    { "id": "44", "x": -5, "y": 22, "z": -135, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "45", "x": 12, "y": 22.5, "z": -132, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "46", "x": -18, "y": 23, "z": -140, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "47", "x": 0, "y": 23.5, "z": -142, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "我们年少时死在了过去，我们成年后依然死在了过去。", "tooltip_en": "We died in the past when we were young, and we still die in the past when we grow up." },
    { "id": "48", "x": -10, "y": 24, "z": -148, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "49", "x": 10, "y": 24.5, "z": -150, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "50", "x": -30, "y": 25, "z": -145, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "51", "x": 20, "y": 25.5, "z": -155, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "已经碎掉的镜子，补好了之后又忘记它碎过，那它就是新的了吗？", "tooltip_en": "A mirror that has been broken, after being repaired and forgetting it was broken, is it new?" },
    { "id": "52", "x": -15, "y": 26, "z": -160, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "53", "x": 5, "y": 26.5, "z": -158, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "54", "x": -5, "y": 27, "z": -168, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "55", "x": 25, "y": 27.5, "z": -165, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "我的人生是一条只能向前推进的窄路。", "tooltip_en": "My life is a narrow path that can only move forward." },
    { "id": "56", "x": -20, "y": 28, "z": -172, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "57", "x": 0, "y": 28.5, "z": -175, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "58", "x": 15, "y": 29, "z": -170, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "59", "x": -10, "y": 29.5, "z": -182, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "在一个充满绝望的地方，没有人会去质疑。", "tooltip_en": "In a place full of despair, no one questions." },
    { "id": "60", "x": 10, "y": 30, "z": -185, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "61", "x": -25, "y": 30.5, "z": -180, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "62", "x": 5, "y": 31, "z": -192, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "63", "x": -5, "y": 31.5, "z": -195, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "这里没有退路，只能向前。", "tooltip_en": "There is no way back, only forward." },
    { "id": "64", "x": 20, "y": 32, "z": -190, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "65", "x": -15, "y": 32.5, "z": -202, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "66", "x": 0, "y": 33, "z": -200, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "67", "x": 15, "y": 33.5, "z": -210, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "碎过的镜子，补好也不是新的。", "tooltip_en": "A broken mirror, even mended, is not new." },
    { "id": "68", "x": -10, "y": 34, "z": -212, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "69", "x": 10, "y": 34.5, "z": -208, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "70", "x": -20, "y": 35, "z": -220, "width": 6, "depth": 6, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "71", "x": 5, "y": 35.5, "z": -222, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "希望是最残忍的东西。", "tooltip_en": "Hope is the cruelest thing." },
    { "id": "72", "x": -5, "y": 36, "z": -230, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "73", "x": 15, "y": 36.5, "z": -228, "width": 5, "depth": 5, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "74", "x": 0, "y": 37, "z": -235, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "没有人会去质疑一份希望的重量。", "tooltip_en": "No one questions the weight of a hope." },
    { "id": "75", "x": 0, "y": 38, "z": -245, "width": 12, "depth": 12, "height": 1, "type": 3, "tooltip": "否定一切之后，还剩什么？", "tooltip_en": "After denying everything, what remains?" }
  ],
