{
  "ver": "3.0",
  "name": "接受",
  "startPosition": { "x": 0, "y": 2, "z": 0 },
  "platforms": [
    { "id": "1", "x": 0, "y": 0.5, "z": 0, "width": 8, "depth": 8, "height": 1, "type": 1, "tooltip": "", "tooltip_en": "" },
    { "id": "2", "x": 10, "y": 1.5, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "3", "x": 20, "y": 2, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "路途之所以有意义是因为它会停止。", "tooltip_en": "The road has meaning because it stops." },
    { "id": "4", "x": 30, "y": 2.5, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "5", "x": 30, "y": 3, "z": -10, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "时间是永远分岔的，通向接受一切的那一条。", "tooltip_en": "Time is forever branching toward the one that accepts everything." },
    { "id": "6", "x": 20, "y": 3.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "7", "x": 10, "y": 4, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "8", "x": 0, "y": 4.5, "z": -10, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "要有耐心对一切尚未结束的事，要学会热爱行走本身。", "tooltip_en": "Have patience with everything unresolved, learn to love the walking itself." },
    { "id": "9", "x": -10, "y": 5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "10", "x": -20, "y": 5.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "11", "x": -20, "y": 6, "z": -20, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "道路载以形，劳以跳跃，息以终点。", "tooltip_en": "The road shapes us, tires us with jumps, rests us at the end." },
    { "id": "12", "x": -10, "y": 6.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "13", "x": 0, "y": 7, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "14", "x": 10, "y": 7.5, "z": -20, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "愿意的话，可以停止；愿意的话，也可以继续。", "tooltip_en": "If you wish, you can stop; if you wish, you can continue." },
    { "id": "15", "x": 20, "y": 8, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "16", "x": 30, "y": 8.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "17", "x": 30, "y": 9, "z": -30, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "结束了？不，开始了。", "tooltip_en": "The end? No, the beginning." },
    { "id": "18", "x": 20, "y": 9.5, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "19", "x": 10, "y": 10, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "20", "x": 0, "y": 10.5, "z": -30, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "接受一切，然后继续走。", "tooltip_en": "Accept everything, then keep walking." },
    { "id": "21", "x": -10, "y": 11, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "22", "x": -20, "y": 11.5, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "23", "x": -20, "y": 12, "z": -40, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "没有人会陪你，但路在脚下。", "tooltip_en": "No one will walk with you, but the road is underfoot." },
    { "id": "24", "x": -10, "y": 12.5, "z": -40, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "25", "x": 0, "y": 13, "z": -40, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "26", "x": 10, "y": 13.5, "z": -40, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "终点？还是起点？", "tooltip_en": "The end? Or the beginning?" },
    { "id": "27", "x": 20, "y": 14, "z": -40, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "28", "x": 30, "y": 14.5, "z": -40, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "29", "x": 30, "y": 15, "z": -50, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "走吧，路会自己走出来。", "tooltip_en": "Walk, and the road will emerge." },
    { "id": "30", "x": 20, "y": 15.5, "z": -50, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "31", "x": 10, "y": 16, "z": -50, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "接受一切，然后放手。", "tooltip_en": "Accept everything, then let go." },
    { "id": "32", "x": 0, "y": 16.5, "z": -50, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "33", "x": -10, "y": 17, "z": -50, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "34", "x": -10, "y": 17.5, "z": -60, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "到了。", "tooltip_en": "Here." },
    { "id": "35", "x": -10, "y": 18, "z": -70, "width": 10, "depth": 10, "height": 1, "type": 3, "tooltip": "结束了。", "tooltip_en": "Over." }
  ],
