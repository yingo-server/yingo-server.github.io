{
  "ver": "3.0",
  "name": "沮丧",
  "startPosition": { "x": 0, "y": 2, "z": 0 },
  "platforms": [
    { "id": "1", "x": 0, "y": 0.5, "z": 0, "width": 8, "depth": 8, "height": 1, "type": 1, "tooltip": "", "tooltip_en": "" },
    { "id": "2", "x": 10, "y": 1.5, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "3", "x": 20, "y": 2, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "对路的要求太高了，世界吐了出来。", "tooltip_en": "Demands on the road were too high; the world spat out." },
    { "id": "4", "x": 30, "y": 3, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "5", "x": 30, "y": 2.5, "z": -10, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "最残酷的事，是面对偌大的世界，成了赤手空拳的俯首就擒者。", "tooltip_en": "The cruelest thing is to face this vast world empty-handed, a captive already." },
    { "id": "6", "x": 20, "y": 2, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "7", "x": 10, "y": 1.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "8", "x": 0, "y": 1, "z": -10, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "最大的能耐就是躺着不动，最擅长的事就是一蹶不振。", "tooltip_en": "The greatest ability is to lie still; the thing I do best is to fall apart." },
    { "id": "9", "x": -10, "y": 1.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "10", "x": -20, "y": 2, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "11", "x": -30, "y": 2.5, "z": -10, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "无论转向何方，总有黑浪迎面打来。", "tooltip_en": "Wherever we turn, dark waves crash upon us." },
    { "id": "12", "x": -40, "y": 3, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "13", "x": -40, "y": 3.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "此生的欢乐不是生命本身的，而是向更高处上升前的恐惧。", "tooltip_en": "The joy of this life is not life itself, but the fear before rising higher." },
    { "id": "14", "x": -30, "y": 4, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "15", "x": -20, "y": 4.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "16", "x": -10, "y": 5, "z": -20, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "生活中最难的，不是在痛苦中坚持，而是在幸福中保持清醒。", "tooltip_en": "The hardest thing in life is not to persist in pain, but to stay awake in happiness." },
    { "id": "17", "x": 0, "y": 5.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "18", "x": 10, "y": 6, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "19", "x": 20, "y": 6.5, "z": -20, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "所有的路都是下坡，直到遇见光。", "tooltip_en": "All roads are downhill until light appears." },
    { "id": "20", "x": 30, "y": 7, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "21", "x": 30, "y": 7.5, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "没有人能够替你承受，也没有人能够抢走你的坚强。", "tooltip_en": "No one can bear it for you, and no one can take away your strength." },
    { "id": "22", "x": 20, "y": 8, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "23", "x": 10, "y": 8.5, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "24", "x": 0, "y": 9, "z": -30, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "在沮丧的尽头，看见一点光亮。", "tooltip_en": "At the end of despair, a glimmer of light appears." },
    { "id": "25", "x": -10, "y": 9.5, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "26", "x": -20, "y": 10, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "27", "x": -30, "y": 10.5, "z": -30, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "路是自己走出来的，即便爬着也要走完。", "tooltip_en": "The road is made by walking, even if crawling." },
    { "id": "28", "x": -30, "y": 11, "z": -40, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "29", "x": -30, "y": 11.5, "z": -50, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "沮丧的尽头，是接受。", "tooltip_en": "At the end of frustration, acceptance." },
    { "id": "30", "x": -30, "y": 12, "z": -60, "width": 10, "depth": 10, "height": 1, "type": 3, "tooltip": "还没结束。", "tooltip_en": "Not over yet." }
  ],
