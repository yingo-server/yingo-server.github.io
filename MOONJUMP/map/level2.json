{
  "ver": "3.0",
  "name": "否定",
  "startPosition": { "x": 0, "y": 2, "z": 0 },
  "platforms": [
    { "id": "1", "x": 0, "y": 0.5, "z": 0, "width": 8, "depth": 8, "height": 1, "type": 1, "tooltip": "", "tooltip_en": "" },
    { "id": "2", "x": 10, "y": 1.5, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "3", "x": 20, "y": 2, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "4", "x": 30, "y": 2.5, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "最高价值的自行贬黜。没有目标；没有对‘为何之故’的回答。", "tooltip_en": "The devaluation of the highest values. No goal; no answer to 'why'." },
    { "id": "5", "x": 40, "y": 3, "z": 0, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "6", "x": 40, "y": 3, "z": -10, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "自己即地狱。", "tooltip_en": "Oneself is hell." },
    { "id": "7", "x": 30, "y": 3.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "8", "x": 20, "y": 4, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "生命是自己行动的结果，此外什么都不是。", "tooltip_en": "Life is nothing other than its own actions, and nothing more." },
    { "id": "9", "x": 10, "y": 4.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "10", "x": 0, "y": 5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "不选择其实就是一种选择。", "tooltip_en": "Not choosing is itself a choice." },
    { "id": "11", "x": -10, "y": 5.5, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "12", "x": -20, "y": 6, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "13", "x": -30, "y": 6.5, "z": -10, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "生活中的每一天都在否定前一天。", "tooltip_en": "Each day of life denies the one before." },
    { "id": "14", "x": -40, "y": 7, "z": -10, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "15", "x": -40, "y": 7, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "孤独就是独立，独立是冷酷的，但也是安静的。", "tooltip_en": "Solitude is independence, cold but quiet." },
    { "id": "16", "x": -30, "y": 7.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "17", "x": -20, "y": 8, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "18", "x": -10, "y": 8.5, "z": -20, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "一切障碍都能摧毁一切。", "tooltip_en": "Every obstacle can destroy everything." },
    { "id": "19", "x": 0, "y": 9, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "20", "x": 10, "y": 9.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "21", "x": 20, "y": 10, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 2, "tooltip": "生命之所以有意义是因为它会停止。", "tooltip_en": "Life has meaning because it stops." },
    { "id": "22", "x": 30, "y": 10.5, "z": -20, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "23", "x": 30, "y": 11, "z": -30, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "24", "x": 20, "y": 11.5, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "撒谎是人之本性，在大多数时间里甚至都不能对自己诚实。", "tooltip_en": "Lying is human nature; most of the time we cannot even be honest with ourselves." },
    { "id": "25", "x": 10, "y": 12, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "26", "x": 0, "y": 12.5, "z": -30, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "27", "x": -10, "y": 13, "z": -30, "width": 8, "depth": 8, "height": 1, "type": 2, "tooltip": "人是被判了自由这样一种徒刑。", "tooltip_en": "Man is condemned to be free." },
    { "id": "28", "x": -10, "y": 13.5, "z": -40, "width": 7, "depth": 7, "height": 1, "type": 0, "tooltip": "", "tooltip_en": "" },
    { "id": "29", "x": -10, "y": 14, "z": -50, "width": 8, "depth": 8, "height": 1, "type": 0, "tooltip": "最大的能耐就是躺着不动，最擅长的事就是一蹶不振。", "tooltip_en": "The greatest ability is to lie still; the thing I do best is to fall apart." },
    { "id": "30", "x": -10, "y": 14.5, "z": -60, "width": 10, "depth": 10, "height": 1, "type": 3, "tooltip": "否定一切之后，还剩什么？", "tooltip_en": "After denying everything, what remains?" }
  ],
