<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>锐角音乐 · 演示版</title>
    <!-- Font Awesome 6 (免费图标库) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            border-radius: 0 !important;
        }

        :root {
            --bg-screen: #0E0E12;
            --bg-card: #1A1A22;
            --bg-input: #14141A;
            --bg-minibar: #16161E;
            --bg-tabbar: #0C0C10;
            --accent: #00C8F0;
            --accent-dim: #0088AA;
            --text-primary: #E8E8F0;
            --text-secondary: #9A9AA8;
            --text-hint: #5E5E6E;
            --border-subtle: #2A2A34;
            --minibar-height: 62px;
            --tabbar-height: 50px;
            --safe-bottom: env(safe-area-inset-bottom, 0px);
        }

        [data-theme="light"] {
            --bg-screen: #ECF4FA;
            --bg-card: #FFFFFF;
            --bg-input: #F0F8FF;
            --bg-minibar: #F5F9FF;
            --bg-tabbar: #EAF4FA;
            --accent: #3088CC;
            --accent-dim: #2266AA;
            --text-primary: #1A1A2E;
            --text-secondary: #5A5A6E;
            --text-hint: #8A8A9E;
            --border-subtle: #D0D0DC;
        }

        html, body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            background: var(--bg-screen);
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
            color: var(--text-primary);
            -webkit-tap-highlight-color: transparent;
            user-select: none;
        }

        #app {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        /* 页面容器 */
        .page {
            position: absolute;
            inset: 0;
            overflow-y: auto;
            overflow-x: hidden;
            padding-bottom: calc(var(--minibar-height) + var(--tabbar-height) + var(--safe-bottom) + 10px);
            display: none;
        }
        .page.active { display: block; }

        /* 底部导航 */
        .tabbar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: calc(var(--tabbar-height) + var(--safe-bottom));
            padding-bottom: var(--safe-bottom);
            background: var(--bg-tabbar);
            display: flex;
            align-items: center;
            justify-content: space-around;
            border-top: 1px solid var(--border-subtle);
            z-index: 100;
        }
        .tabbar-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            font-size: 10px;
            color: var(--text-hint);
            cursor: pointer;
            transition: color 0.2s;
            min-width: 48px;
            padding: 4px 0;
        }
        .tabbar-item.active { color: var(--accent); }
        .tabbar-item i { font-size: 22px; }

        /* 迷你播放栏 */
        .minibar {
            position: fixed;
            bottom: calc(var(--tabbar-height) + var(--safe-bottom));
            left: 0;
            right: 0;
            height: var(--minibar-height);
            background: var(--bg-minibar);
            display: flex;
            align-items: center;
            padding: 0 14px;
            gap: 12px;
            border-top: 1px solid var(--border-subtle);
            cursor: pointer;
            z-index: 99;
        }
        .minibar-cover {
            width: 44px;
            height: 44px;
            background: var(--bg-card);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-hint);
            font-size: 12px;
            overflow: hidden;
        }
        .minibar-cover img { width: 100%; height: 100%; object-fit: cover; }
        .minibar-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; gap: 2px; overflow: hidden; }
        .minibar-title { font-size: 14px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .minibar-lyric { font-size: 11px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .minibar-btn {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }
        .minibar-btn i { font-size: 28px; color: var(--accent); }

        /* 全屏播放器 */
        .player-full {
            position: fixed;
            inset: 0;
            background: var(--bg-screen);
            z-index: 200;
            display: none;
            flex-direction: column;
            transform: translateY(100%);
            transition: transform 0.35s cubic-bezier(0.33, 0.9, 0.38, 1.02);
        }
        .player-full.show { display: flex; transform: translateY(0); }
        .player-close {
            position: absolute;
            top: 16px;
            left: 16px;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-hint);
        }
        .player-close i { font-size: 24px; }
        .player-upper {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 50px 30px 20px;
            position: relative;
            overflow: hidden;
        }
        .player-cover {
            width: min(280px, 70vw);
            height: min(280px, 70vw);
            background: var(--bg-card);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-hint);
            font-size: 14px;
            overflow: hidden;
        }
        .player-cover img { width: 100%; height: 100%; object-fit: cover; }
        .player-lyric-page {
            position: absolute;
            inset: 0;
            padding: 60px 24px 20px;
            overflow-y: auto;
            display: none;
            flex-direction: column;
            gap: 12px;
            align-items: center;
            text-align: center;
        }
        .player-lyric-page.show { display: flex; }
        .lyric-line { font-size: 15px; color: var(--text-secondary); transition: all 0.2s; line-height: 1.8; }
        .lyric-line.active { color: var(--accent); font-size: 18px; font-weight: 500; }
        .player-lower {
            padding: 10px 24px calc(30px + var(--safe-bottom));
            display: flex;
            flex-direction: column;
            gap: 14px;
        }
        .player-progress-row {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .player-time { font-size: 11px; color: var(--text-hint); min-width: 36px; text-align: center; }
        .player-progress {
            flex: 1;
            height: 4px;
            background: var(--border-subtle);
            position: relative;
            cursor: pointer;
        }
        .player-progress-fill {
            height: 100%;
            background: var(--accent);
            width: 0%;
        }
        .player-controls {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 24px;
        }
        .player-ctrl-btn {
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: transform 0.1s;
            color: var(--text-primary);
        }
        .player-ctrl-btn i { font-size: 28px; }
        .player-ctrl-btn:active { transform: scale(0.85); }
        .player-ctrl-btn.main-play { width: 58px; height: 58px; }
        .player-ctrl-btn.main-play i { font-size: 42px; color: var(--accent); }
        .playlist-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.85);
            z-index: 250;
            display: none;
            align-items: flex-end;
            justify-content: center;
        }
        .playlist-overlay.show { display: flex; }
        .playlist-panel {
            width: 100%;
            max-height: 60vh;
            background: var(--bg-card);
            border-top: 2px solid var(--accent);
            overflow-y: auto;
            transform: translateY(100%);
            transition: transform 0.32s;
        }
        .playlist-overlay.show .playlist-panel { transform: translateY(0); }
        .playlist-item {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            gap: 12px;
            cursor: pointer;
            border-bottom: 1px solid var(--border-subtle);
        }
        .playlist-item:active { background: var(--bg-screen); }
        .playlist-item.current { color: var(--accent); }
        .playlist-item-index { width: 24px; text-align: center; font-size: 12px; color: var(--text-hint); }
        .playlist-item-info { flex: 1; min-width: 0; }
        .playlist-item-name { font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .playlist-item-author { font-size: 11px; color: var(--text-hint); }

        /* 首页样式 */
        .home-search-bar {
            margin: 14px 16px;
            height: 42px;
            background: var(--bg-input);
            border: 1px solid var(--border-subtle);
            display: flex;
            align-items: center;
            padding: 0 14px;
            cursor: pointer;
        }
        .home-search-bar i { font-size: 16px; color: var(--text-hint); margin-right: 8px; }
        .home-search-bar span { font-size: 14px; color: var(--text-hint); }
        .section-title {
            font-size: 16px;
            font-weight: 600;
            padding: 0 16px;
            margin-bottom: 12px;
        }
        .scroll-h {
            display: flex;
            gap: 12px;
            overflow-x: auto;
            padding: 0 16px;
        }
        .song-card-h {
            flex-shrink: 0;
            width: 120px;
            cursor: pointer;
        }
        .song-card-h .card-cover {
            width: 120px;
            height: 120px;
            background: var(--bg-card);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-hint);
            font-size: 12px;
            overflow: hidden;
        }
        .song-card-h .card-cover img { width: 100%; height: 100%; object-fit: cover; }
        .song-card-h .card-name { font-size: 13px; margin-top: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .song-card-h .card-author { font-size: 11px; color: var(--text-hint); }
        .song-list-v {
            display: flex;
            flex-direction: column;
            padding: 0 16px;
        }
        .song-item-v {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 0;
            cursor: pointer;
            border-bottom: 1px solid var(--border-subtle);
        }
        .song-item-v .item-index { width: 22px; text-align: center; font-size: 13px; color: var(--text-hint); }
        .song-item-v .item-info { flex: 1; min-width: 0; }
        .song-item-v .item-name { font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .song-item-v .item-author { font-size: 11px; color: var(--text-hint); margin-top: 1px; }

        /* 我的页面 */
        .my-header {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 24px 18px 18px;
            border-bottom: 1px solid var(--border-subtle);
        }
        .my-avatar {
            width: 60px;
            height: 60px;
            background: var(--bg-card);
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-hint);
        }
        .my-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .my-info { flex: 1; }
        .my-nickname { font-size: 17px; font-weight: 600; }
        .my-meta { font-size: 12px; color: var(--text-hint); margin-top: 3px; }
        .my-vip-badge { font-size: 10px; color: var(--accent); padding: 2px 6px; border: 1px solid var(--accent); display: inline-block; margin-top: 4px; }
        .my-detail-wrap { margin: 12px 18px; border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); }
        .my-detail-toggle {
            font-size: 13px;
            color: var(--accent);
            padding: 10px 0;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .my-detail-toggle i { font-size: 12px; transition: transform 0.2s; }
        .my-detail-toggle.expanded i { transform: rotate(180deg); }
        .my-detail-content { display: none; padding-bottom: 10px; }
        .my-detail-content.show { display: block; }
        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            font-size: 12px;
        }
        .detail-label { color: var(--text-hint); }
        .my-playlist-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 13px 18px;
            cursor: pointer;
            border-bottom: 1px solid var(--border-subtle);
        }
        .my-playlist-cover {
            width: 46px;
            height: 46px;
            background: var(--bg-card);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-hint);
            overflow: hidden;
        }
        .my-playlist-cover img { width: 100%; height: 100%; object-fit: cover; }
        .my-playlist-info { flex: 1; }
        .my-playlist-name { font-size: 14px; }
        .my-playlist-count { font-size: 11px; color: var(--text-hint); margin-top: 2px; }

        /* 登录浮层 */
        .login-overlay {
            position: fixed;
            inset: 0;
            z-index: 500;
            background: var(--bg-screen);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .login-overlay.show { display: flex; }
        .login-dialog {
            width: 100%;
            max-width: 380px;
            background: var(--bg-card);
            border-top: 3px solid var(--accent);
            padding: 24px 20px 28px;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }
        .login-tabs {
            display: flex;
            gap: 16px;
            border-bottom: 2px solid var(--border-subtle);
            padding-bottom: 10px;
            position: relative;
        }
        .login-tab {
            font-size: 15px;
            font-weight: 500;
            color: var(--text-hint);
            cursor: pointer;
            padding-bottom: 8px;
        }
        .login-tab.active { color: var(--accent); }
        .login-tab-slider {
            position: absolute;
            bottom: -2px;
            height: 2px;
            background: var(--accent);
            transition: left 0.35s, width 0.35s;
        }
        .login-input {
            width: 75%;
            height: 42px;
            background: var(--bg-input);
            border: 1px solid var(--border-subtle);
            padding: 0 12px;
            font-size: 15px;
            align-self: center;
        }
        .login-input:focus { border-color: var(--accent); outline: none; }
        .login-send-btn {
            width: 75%;
            align-self: center;
            text-align: center;
            font-size: 13px;
            color: var(--accent);
            cursor: pointer;
            padding: 8px 0;
        }
        .login-submit {
            width: 75%;
            height: 44px;
            background: var(--accent);
            color: #121218;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            align-self: center;
            border: none;
        }
        .login-qr {
            align-self: center;
            width: 150px;
            height: 150px;
            background: var(--bg-input);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: var(--text-hint);
            text-align: center;
        }
        .login-qr img { width: 100%; height: 100%; object-fit: contain; }

        /* 搜索浮层 */
        .search-page {
            position: fixed;
            inset: 0;
            background: var(--bg-screen);
            z-index: 180;
            display: none;
            flex-direction: column;
        }
        .search-page.show { display: flex; }
        .search-top {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border-bottom: 1px solid var(--border-subtle);
        }
        .search-input-wrap {
            flex: 1;
            height: 38px;
            background: var(--bg-input);
            border: 1px solid var(--border-subtle);
            display: flex;
            align-items: center;
            padding: 0 12px;
        }
        .search-input-wrap input {
            flex: 1;
            height: 100%;
            font-size: 14px;
            background: none;
            border: 0;
            outline: none;
            color: var(--text-primary);
        }
        .search-cancel {
            font-size: 14px;
            color: var(--text-hint);
            cursor: pointer;
            padding: 8px 4px;
        }
        .search-results { flex: 1; overflow-y: auto; }

        /* Toast */
        .toast {
            position: fixed;
            top: 28px;
            right: 16px;
            background: var(--bg-card);
            color: var(--text-primary);
            padding: 12px 18px;
            border-left: 3px solid var(--accent);
            z-index: 9999;
            font-size: 13px;
            transform: translateX(130%);
            transition: transform 0.32s;
            max-width: 260px;
        }
        .toast.show { transform: translateX(0); }

        @media (min-width: 420px) {
            .player-cover { width: 300px; height: 300px; }
        }
    </style>
</head>
<body>
<div id="app"></div>

<script>
    (function(){
        // ---------- 模拟数据 ----------
        const mockSongs = [
            { id:1, name:"夜曲", singer:"周杰伦", cover:"https://picsum.photos/120/120?random=1", lyric:"一群嗜血的蚂蚁 被腐肉所吸引" },
            { id:2, name:"稻香", singer:"周杰伦", cover:"https://picsum.photos/120/120?random=2", lyric:"还记得你说家是唯一的城堡" },
            { id:3, name:"海阔天空", singer:"BEYOND", cover:"https://picsum.photos/120/120?random=3", lyric:"原谅我这一生不羁放纵爱自由" },
            { id:4, name:"平凡之路", singer:"朴树", cover:"https://picsum.photos/120/120?random=4", lyric:"我曾经跨过山和大海" },
            { id:5, name:"晴天", singer:"周杰伦", cover:"https://picsum.photos/120/120?random=5", lyric:"故事的小黄花 从出生那年就飘着" },
            { id:6, name:"遇见", singer:"孙燕姿", cover:"https://picsum.photos/120/120?random=6", lyric:"听见 冬天的离开" },
        ];

        // 模拟歌单列表（我的页面）
        let mockPlaylists = [
            { id:1, name:"我喜欢的音乐", count:28, cover:"https://picsum.photos/46/46?random=10" },
            { id:2, name:"跑步歌单", count:15, cover:"https://picsum.photos/46/46?random=11" },
            { id:3, name:"经典老歌", count:42, cover:"https://picsum.photos/46/46?random=12" }
        ];

        // 模拟歌单内的歌曲（从新到旧，即索引0最新）
        function generatePlaylistSongs(total) {
            let songs = [];
            for(let i=0; i<total; i++) {
                songs.push({
                    id: 1000+i,
                    name: `模拟歌曲 ${total-i}`,
                    singer: `歌手${(i%5)+1}`,
                    cover: `https://picsum.photos/120/120?random=${2000+i}`,
                    lyric: `这是第${total-i}首歌的歌词内容`
                });
            }
            return songs;
        }

        let currentPlaylistSongs = generatePlaylistSongs(120); // 120首模拟歌曲，用于测试分页

        // 当前播放状态
        let currentSong = null;
        let playing = false;
        let audio = new Audio();
        let timer = null;
        let currentPlaylist = [];   // 当前播放列表（用于播放器）
        let currentPlayIndex = 0;

        // DOM 元素引用
        let app, homePage, myPage, playlistPage, searchPage, loginOverlay, minibar, fullPlayer;
        let currentView = 'home';

        // 工具函数
        function showToast(msg) {
            let toast = document.querySelector('.toast');
            if(!toast){
                toast = document.createElement('div');
                toast.className = 'toast';
                document.body.appendChild(toast);
            }
            toast.textContent = msg;
            toast.classList.add('show');
            clearTimeout(toast._timer);
            toast._timer = setTimeout(()=> toast.classList.remove('show'), 2000);
        }

        function formatTime(sec) {
            if(!sec || isNaN(sec)) return '00:00';
            let m = Math.floor(sec/60);
            let s = Math.floor(sec%60);
            return `${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }

        function setImageWithFallback(container, url, fallback='---') {
            if(!container) return;
            if(!url) { container.textContent = fallback; return; }
            const img = new Image();
            img.onload = () => {
                container.innerHTML = '';
                container.appendChild(img);
            };
            img.onerror = () => { container.textContent = fallback; };
            img.src = url;
        }

        // 主题切换
        function setThemeByTime() {
            const hour = new Date().getHours();
            const isLight = hour >= 6 && hour < 18;
            document.documentElement.setAttribute('data-theme', isLight ? 'light' : 'dark');
        }
        setThemeByTime();
        setInterval(setThemeByTime, 60000);

        // ---------- 页面渲染 ----------
        function buildUI() {
            app = document.getElementById('app');
            app.innerHTML = `
                <div id="homePage" class="page active"></div>
                <div id="myPage" class="page"></div>
                <div id="playlistPage" class="page"></div>
                <div id="searchPage" class="search-page"></div>
                <div id="loginOverlay" class="login-overlay"></div>
                <div class="tabbar">
                    <div class="tabbar-item" data-page="home"><i class="fas fa-home"></i><span>首页</span></div>
                    <div class="tabbar-item" data-page="my"><i class="fas fa-user"></i><span>我的</span></div>
                </div>
                <div class="minibar" id="minibar">
                    <div class="minibar-cover" id="minibarCover">---</div>
                    <div class="minibar-info">
                        <div class="minibar-title" id="minibarTitle">未在播放</div>
                        <div class="minibar-lyric" id="minibarLyric">点击播放音乐</div>
                    </div>
                    <div class="minibar-btn" id="minibarPlayBtn"><i class="fas fa-play"></i></div>
                </div>
                <div id="fullPlayer" class="player-full">
                    <div class="player-close" id="playerClose"><i class="fas fa-arrow-left"></i></div>
                    <div class="player-upper">
                        <div class="player-cover" id="playerCover">---</div>
                        <div class="player-lyric-page" id="playerLyricPage"></div>
                    </div>
                    <div class="player-lower">
                        <div class="player-progress-row">
                            <span class="player-time" id="playerTimeCur">00:00</span>
                            <div class="player-progress" id="playerProgressBar"><div class="player-progress-fill" id="playerProgressFill"></div></div>
                            <span class="player-time" id="playerTimeTotal">00:00</span>
                        </div>
                        <div class="player-controls">
                            <div class="player-ctrl-btn" id="playerModeBtn"><i class="fas fa-repeat"></i></div>
                            <div class="player-ctrl-btn" id="playerPrevBtn"><i class="fas fa-backward-step"></i></div>
                            <div class="player-ctrl-btn main-play" id="playerMainPlay"><i class="fas fa-play"></i></div>
                            <div class="player-ctrl-btn" id="playerNextBtn"><i class="fas fa-forward-step"></i></div>
                            <div class="player-ctrl-btn" id="playerListBtn"><i class="fas fa-list"></i></div>
                        </div>
                    </div>
                    <div class="playlist-overlay" id="playlistOverlay">
                        <div class="playlist-panel" id="playlistPanel"></div>
                    </div>
                </div>
            `;
            homePage = document.getElementById('homePage');
            myPage = document.getElementById('myPage');
            playlistPage = document.getElementById('playlistPage');
            searchPage = document.getElementById('searchPage');
            loginOverlay = document.getElementById('loginOverlay');
            minibar = document.getElementById('minibar');
            fullPlayer = document.getElementById('fullPlayer');

            // 绑定底部tab
            document.querySelectorAll('.tabbar-item').forEach(t => {
                t.addEventListener('click', () => switchView(t.dataset.page));
            });
            // 迷你栏点击
            minibar.addEventListener('click', () => showFullPlayer());
            document.getElementById('minibarPlayBtn').addEventListener('click', (e) => { e.stopPropagation(); togglePlay(); });
            // 全屏播放器控制
            document.getElementById('playerClose').addEventListener('click', hideFullPlayer);
            document.getElementById('playerModeBtn').addEventListener('click', cycleMode);
            document.getElementById('playerPrevBtn').addEventListener('click', prev);
            document.getElementById('playerMainPlay').addEventListener('click', togglePlay);
            document.getElementById('playerNextBtn').addEventListener('click', next);
            document.getElementById('playerListBtn').addEventListener('click', showPlaylistPanel);
            document.getElementById('playerProgressBar').addEventListener('click', seekProgress);
            document.getElementById('playlistOverlay').addEventListener('click', (e) => {
                if(e.target.id === 'playlistOverlay') hidePlaylistPanel();
            });
            // 歌词滑动
            const upper = document.getElementById('playerUpper');
            let startY = 0;
            upper.addEventListener('touchstart', e => { startY = e.touches[0].clientY; });
            upper.addEventListener('touchend', e => {
                const dy = startY - e.changedTouches[0].clientY;
                if(dy > 60) {
                    document.getElementById('playerCover').style.display = 'none';
                    document.getElementById('playerLyricPage').classList.add('show');
                } else if(dy < -60) {
                    document.getElementById('playerCover').style.display = '';
                    document.getElementById('playerLyricPage').classList.remove('show');
                }
            });

            buildHome();
            buildSearch();
            buildLogin();
            loadMyPage();      // 我的页面模拟数据
        }

        function switchView(view) {
            if(currentView === view) return;
            currentView = view;
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(view+'Page').classList.add('active');
            document.querySelectorAll('.tabbar-item').forEach(t => {
                t.classList.toggle('active', t.dataset.page === view);
            });
            if(view === 'my') loadMyPage();  // 每次进入刷新
        }

        // 首页
        function buildHome() {
            homePage.innerHTML = `
                <div class="home-search-bar" id="homeSearchBar"><i class="fas fa-search"></i><span>搜索音乐</span></div>
                <div class="section"><div class="section-title">每日推荐</div><div class="scroll-h" id="dailyScroll"></div></div>
                <div class="section"><div class="section-title">猜你喜欢</div><div class="song-list-v" id="fmList"></div></div>
                <div class="section"><div class="section-title">新歌速递</div><div class="song-list-v" id="hotList"></div></div>
            `;
            document.getElementById('homeSearchBar').onclick = () => {
                searchPage.classList.add('show');
                setTimeout(() => document.getElementById('searchInput').focus(), 150);
            };
            // 填充模拟数据
            const daily = mockSongs.slice(0, 5);
            const fm = mockSongs.slice(0, 8);
            const hot = mockSongs.slice(0, 10);
            renderScrollCards('dailyScroll', daily);
            renderSongList('fmList', fm);
            renderSongList('hotList', hot);
        }

        function renderScrollCards(containerId, songs) {
            const container = document.getElementById(containerId);
            if(!container) return;
            container.innerHTML = '';
            songs.forEach(s => {
                const card = document.createElement('div');
                card.className = 'song-card-h';
                card.onclick = () => playSong(s, songs, songs.indexOf(s));
                card.innerHTML = `
                    <div class="card-cover">${s.cover ? `<img src="${s.cover}" onerror="this.style.display='none';this.parentElement.textContent='---'">` : '---'}</div>
                    <div class="card-name">${s.name}</div>
                    <div class="card-author">${s.singer}</div>
                `;
                container.appendChild(card);
            });
        }

        function renderSongList(containerId, songs) {
            const container = document.getElementById(containerId);
            if(!container) return;
            container.innerHTML = '';
            songs.forEach((s, idx) => {
                const div = document.createElement('div');
                div.className = 'song-item-v';
                div.onclick = () => playSong(s, songs, idx);
                div.innerHTML = `
                    <div class="item-index">${idx+1}</div>
                    <div class="item-info">
                        <div class="item-name">${s.name}</div>
                        <div class="item-author">${s.singer}</div>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        // 我的页面
        function loadMyPage() {
            myPage.innerHTML = `
                <div class="my-header">
                    <div class="my-avatar" id="myAvatar"><img src="https://picsum.photos/60/60?random=100" alt="avatar"></div>
                    <div class="my-info">
                        <div class="my-nickname">模拟用户</div>
                        <div class="my-meta">关注 12  |  粉丝 34</div>
                        <div class="my-vip-badge">VIP</div>
                    </div>
                </div>
                <div class="my-detail-wrap">
                    <div class="my-detail-toggle" id="detailToggle">详细信息 <i class="fas fa-chevron-down"></i></div>
                    <div class="my-detail-content" id="detailContent"></div>
                </div>
                <div class="my-playlist" id="myPlaylist"></div>
            `;
            // 模拟详细信息
            const detailRows = [
                ['昵称','模拟用户'],['所在地','北京'],['性别','男'],['简介','这是一个模拟账号'],
                ['VIP类型','VIP'],['VIP到期','2099-12-31'],['超级VIP等级','Lv.3'],['听歌时长(秒)','12345']
            ];
            const contentDiv = document.getElementById('detailContent');
            detailRows.forEach(([label,val]) => {
                const row = document.createElement('div');
                row.className = 'detail-row';
                row.innerHTML = `<span class="detail-label">${label}</span><span class="detail-value">${val}</span>`;
                contentDiv.appendChild(row);
            });
            document.getElementById('detailToggle').onclick = () => {
                const cont = document.getElementById('detailContent');
                const toggle = document.getElementById('detailToggle');
                cont.classList.toggle('show');
                toggle.classList.toggle('expanded');
            };
            const playlistContainer = document.getElementById('myPlaylist');
            playlistContainer.innerHTML = '';
            mockPlaylists.forEach(pl => {
                const div = document.createElement('div');
                div.className = 'my-playlist-item';
                div.onclick = () => openPlaylist(pl);
                div.innerHTML = `
                    <div class="my-playlist-cover">${pl.cover ? `<img src="${pl.cover}">` : '---'}</div>
                    <div class="my-playlist-info">
                        <div class="my-playlist-name">${pl.name}</div>
                        <div class="my-playlist-count">${pl.count} 首</div>
                    </div>
                `;
                playlistContainer.appendChild(div);
            });
        }

        // 歌单预览（从新到旧分页）
        let currentPlaylistObj = null;
        let playlistSongs = [];
        let playlistTotal = 0;
        let playlistPage = 1;
        let playlistMaxPage = 1;
        let playlistLoading = false;

        function openPlaylist(pl) {
            currentPlaylistObj = pl;
            playlistTotal = pl.count;
            playlistMaxPage = Math.ceil(playlistTotal / 50);
            playlistPage = playlistMaxPage;  // 从最后一页开始（最新）
            playlistSongs = [];
            playlistLoading = false;
            renderPlaylistPage();
            loadMorePlaylistSongs(true);
        }

        function renderPlaylistPage() {
            playlistPage.innerHTML = `
                <div style="display:flex;align-items:center;padding:14px 16px;gap:12px;border-bottom:1px solid var(--border-subtle);">
                    <div style="cursor:pointer;font-size:20px;color:var(--text-hint);" id="plBackBtn"><i class="fas fa-arrow-left"></i></div>
                    <div style="flex:1;font-weight:500;">${currentPlaylistObj.name} (${playlistTotal}首)</div>
                    <div style="color:var(--accent);cursor:pointer;font-size:13px;" id="plPlayAllBtn">全部播放</div>
                </div>
                <div class="song-list-v" id="plSongList" style="padding-bottom:100px;"></div>
                <div id="plLoadMore" style="text-align:center;padding:14px;color:var(--text-hint);"></div>
            `;
            document.getElementById('plBackBtn').onclick = () => switchView('my');
            document.getElementById('plPlayAllBtn').onclick = () => {
                if(playlistSongs.length < playlistTotal) {
                    showToast('正在加载全部歌曲...');
                    // 同步加载所有页（模拟）
                    (async ()=>{
                        for(let p=playlistMaxPage; p>=1; p--) {
                            await loadPageSongs(p, true);
                        }
                        if(playlistSongs.length) playSong(playlistSongs[0], playlistSongs, 0);
                    })();
                } else {
                    if(playlistSongs.length) playSong(playlistSongs[0], playlistSongs, 0);
                }
            };
            const listEl = document.getElementById('plSongList');
            listEl.addEventListener('scroll', () => {
                if(listEl.scrollTop + listEl.clientHeight >= listEl.scrollHeight - 100 && !playlistLoading && playlistPage > 1) {
                    loadMorePlaylistSongs();
                }
            });
        }

        async function loadPageSongs(pageNum, isSilent = false) {
            // 模拟异步加载，实际上所有数据已经在 currentPlaylistSongs 中，我们按页截取
            const perPage = 50;
            const start = (pageNum-1)*perPage;
            const end = start+perPage;
            const pageData = currentPlaylistSongs.slice(start, end);
            // 注意：这里需要反转顺序，因为我们要的是新歌在前（API返回可能是旧到新）
            // 由于我们是从最后一页往前加载，每页内数据要反转
            const reversed = [...pageData].reverse();
            return reversed;
        }

        async function loadMorePlaylistSongs(isFirst=false) {
            if(playlistLoading) return;
            playlistLoading = true;
            const loadHint = document.getElementById('plLoadMore');
            if(loadHint) loadHint.textContent = '加载中...';
            const songs = await loadPageSongs(playlistPage);
            if(songs.length) {
                playlistSongs = [...playlistSongs, ...songs];
                const listEl = document.getElementById('plSongList');
                if(listEl) {
                    // 重新渲染全部（简单处理，实际可增量）
                    listEl.innerHTML = '';
                    playlistSongs.forEach((s, idx) => {
                        const div = document.createElement('div');
                        div.className = 'song-item-v';
                        div.innerHTML = `<div class="item-index">${idx+1}</div><div class="item-info"><div class="item-name">${s.name}</div><div class="item-author">${s.singer}</div></div>`;
                        div.onclick = () => playSong(s, playlistSongs, idx);
                        listEl.appendChild(div);
                    });
                }
                playlistPage--;
            }
            if(loadHint) loadHint.textContent = playlistPage < 1 ? '已加载全部' : '上滑加载更多';
            playlistLoading = false;
        }

        // 搜索
        function buildSearch() {
            searchPage.innerHTML = `
                <div class="search-top">
                    <div class="search-input-wrap"><input type="text" id="searchInput" placeholder="搜索音乐、歌手、歌词"></div>
                    <span class="search-cancel" id="searchCancel">取消</span>
                </div>
                <div class="search-results song-list-v" id="searchResults"></div>
            `;
            const input = document.getElementById('searchInput');
            input.addEventListener('input', (e) => {
                const kw = e.target.value.trim();
                const resultsDiv = document.getElementById('searchResults');
                if(!kw) { resultsDiv.innerHTML = ''; return; }
                const filtered = mockSongs.filter(s => s.name.includes(kw) || s.singer.includes(kw));
                if(filtered.length === 0) {
                    resultsDiv.innerHTML = '<span style="padding:20px;">未找到结果</span>';
                    return;
                }
                resultsDiv.innerHTML = '';
                filtered.forEach((s, idx) => {
                    const div = document.createElement('div');
                    div.className = 'song-item-v';
                    div.onclick = () => playSong(s, filtered, idx);
                    div.innerHTML = `<div class="item-index">${idx+1}</div><div class="item-info"><div class="item-name">${s.name}</div><div class="item-author">${s.singer}</div></div>`;
                    resultsDiv.appendChild(div);
                });
            });
            document.getElementById('searchCancel').onclick = () => {
                searchPage.classList.remove('show');
                document.getElementById('searchInput').value = '';
                document.getElementById('searchResults').innerHTML = '';
            };
        }

        // 登录模拟
        function buildLogin() {
            loginOverlay.innerHTML = `
                <div class="login-dialog">
                    <div class="login-tabs">
                        <span class="login-tab active" data-idx="0">验证码登录</span>
                        <span class="login-tab" data-idx="1">扫码登录</span>
                        <span class="login-tab" data-idx="2">密码登录</span>
                        <div class="login-tab-slider" id="loginTabSlider"></div>
                    </div>
                    <div style="position:relative;min-height:200px;">
                        <div data-panel="0" style="display:flex;flex-direction:column;gap:14px;">
                            <input class="login-input" id="loginMobile" type="tel" placeholder="手机号" maxlength="11">
                            <input class="login-input" id="loginCode" type="text" placeholder="验证码" maxlength="6">
                            <div class="login-send-btn" id="loginSendBtn">获取验证码</div>
                        </div>
                        <div data-panel="1" style="display:none;justify-content:center;">
                            <div class="login-qr" id="loginQrBox">演示二维码<br><i class="fas fa-qrcode" style="font-size:80px;"></i></div>
                        </div>
                        <div data-panel="2" style="display:none;flex-direction:column;gap:14px;">
                            <input class="login-input" id="loginUser" type="text" placeholder="用户名">
                            <input class="login-input" id="loginPass" type="password" placeholder="密码">
                        </div>
                    </div>
                    <button class="login-submit" id="loginSubmit">登 录</button>
                </div>
            `;
            let loginTab = 0;
            const tabs = document.querySelectorAll('.login-tab');
            const panels = document.querySelectorAll('[data-panel]');
            const slider = document.getElementById('loginTabSlider');
            function updateSlider() {
                const activeTab = tabs[loginTab];
                slider.style.left = activeTab.offsetLeft + 'px';
                slider.style.width = activeTab.offsetWidth + 'px';
            }
            tabs.forEach((t,i) => {
                t.addEventListener('click', () => {
                    loginTab = i;
                    tabs.forEach((tt,ii)=> tt.classList.toggle('active', ii===i));
                    panels.forEach(p => p.style.display = parseInt(p.dataset.panel)===i ? 'flex' : 'none');
                    updateSlider();
                });
            });
            updateSlider();
            document.getElementById('loginSendBtn').onclick = () => showToast('模拟发送验证码');
            document.getElementById('loginSubmit').onclick = () => {
                showToast('模拟登录成功');
                loginOverlay.classList.remove('show');
                // 登录后刷新我的页面
                loadMyPage();
            };
            // 显示登录 (模拟未登录状态)
            setTimeout(() => {
                if(!localStorage.getItem('mock_logged')) {
                    loginOverlay.classList.add('show');
                }
            }, 500);
            // 允许关闭（点击遮罩关闭）
            loginOverlay.addEventListener('click', (e) => {
                if(e.target === loginOverlay) loginOverlay.classList.remove('show');
            });
        }

        // 播放器逻辑
        let currentPlaylistGlobal = [];   // 当前播放队列
        let currentPlayIdx = -1;
        let mode = 0; // 0列表 1单曲 2随机

        function playSong(song, playlist, idx) {
            if(!song) return;
            currentPlaylistGlobal = playlist;
            currentPlayIdx = idx;
            currentSong = song;
            // 模拟播放
            if(audio.src) audio.pause();
            // 由于没有真实音频，我们模拟一个空音频（实际可加载一个占位音频，或者直接无声音）
            // 这里模拟播放状态更新UI
            playing = true;
            updateMiniPlayer(song);
            updateFullPlayer(song);
            startProgressSimulation();
            showToast(`正在播放: ${song.name} - ${song.singer}`);
            // 模拟歌词
            if(song.lyric) {
                const lyrics = song.lyric.split('\n').map(line => ({ time:0, text:line }));
                // 简单显示静态歌词
                const lyricPage = document.getElementById('playerLyricPage');
                lyricPage.innerHTML = '';
                lyrics.forEach(l => {
                    const div = document.createElement('div');
                    div.className = 'lyric-line';
                    div.textContent = l.text;
                    lyricPage.appendChild(div);
                });
            }
        }

        function updateMiniPlayer(song) {
            document.getElementById('minibarTitle').textContent = `${song.name} - ${song.singer}`;
            setImageWithFallback(document.getElementById('minibarCover'), song.cover);
            document.getElementById('minibarLyric').textContent = song.lyric ? song.lyric.split('\n')[0] : '点击播放音乐';
        }

        function updateFullPlayer(song) {
            document.getElementById('playerCover').innerHTML = '';
            setImageWithFallback(document.getElementById('playerCover'), song.cover);
            document.getElementById('playerTimeCur').textContent = '00:00';
            document.getElementById('playerTimeTotal').textContent = '03:30';
            document.getElementById('playerProgressFill').style.width = '0%';
        }

        function startProgressSimulation() {
            if(timer) clearInterval(timer);
            let progress = 0;
            timer = setInterval(() => {
                if(!playing) return;
                progress += 1;
                if(progress >= 100) {
                    clearInterval(timer);
                    timer = null;
                    // 自动下一首
                    if(mode === 1) {
                        // 单曲循环重播
                        playSong(currentSong, currentPlaylistGlobal, currentPlayIdx);
                    } else {
                        next();
                    }
                } else {
                    document.getElementById('playerProgressFill').style.width = progress + '%';
                    document.getElementById('playerTimeCur').textContent = formatTime(progress * 2.1);
                }
            }, 100);
        }

        function togglePlay() {
            if(!currentSong) {
                // 如果没有播放，默认播放第一首推荐
                if(mockSongs.length) playSong(mockSongs[0], mockSongs, 0);
                return;
            }
            playing = !playing;
            updatePlayButton();
            if(playing) {
                startProgressSimulation();
            } else {
                if(timer) clearInterval(timer);
                timer = null;
            }
        }

        function updatePlayButton() {
            const icon = playing ? '<i class="fas fa-pause"></i>' : '<i class="fas fa-play"></i>';
            document.getElementById('minibarPlayBtn').innerHTML = icon;
            document.getElementById('playerMainPlay').innerHTML = icon;
        }

        function prev() {
            if(!currentPlaylistGlobal.length) return;
            let newIdx = currentPlayIdx - 1;
            if(newIdx < 0) newIdx = currentPlaylistGlobal.length - 1;
            playSong(currentPlaylistGlobal[newIdx], currentPlaylistGlobal, newIdx);
        }

        function next() {
            if(!currentPlaylistGlobal.length) return;
            let newIdx = currentPlayIdx + 1;
            if(newIdx >= currentPlaylistGlobal.length) newIdx = 0;
            playSong(currentPlaylistGlobal[newIdx], currentPlaylistGlobal, newIdx);
        }

        function cycleMode() {
            mode = (mode + 1) % 3;
            const btn = document.getElementById('playerModeBtn');
            if(btn) btn.classList.toggle('active', mode !== 0);
            const modeNames = ['列表循环','单曲循环','随机播放'];
            showToast(modeNames[mode]);
        }

        function showPlaylistPanel() {
            const panel = document.getElementById('playlistPanel');
            panel.innerHTML = '';
            currentPlaylistGlobal.forEach((s, i) => {
                const div = document.createElement('div');
                div.className = 'playlist-item' + (i === currentPlayIdx ? ' current' : '');
                div.innerHTML = `<div class="playlist-item-index">${i+1}</div><div class="playlist-item-info"><div class="playlist-item-name">${s.name}</div><div class="playlist-item-author">${s.singer}</div></div>`;
                div.onclick = () => {
                    playSong(s, currentPlaylistGlobal, i);
                    hidePlaylistPanel();
                };
                panel.appendChild(div);
            });
            document.getElementById('playlistOverlay').classList.add('show');
        }

        function hidePlaylistPanel() {
            document.getElementById('playlistOverlay').classList.remove('show');
        }

        function showFullPlayer() {
            fullPlayer.classList.add('show');
            document.body.style.overflow = 'hidden';
        }
        function hideFullPlayer() {
            fullPlayer.classList.remove('show');
            document.body.style.overflow = '';
        }
        function seekProgress(e) {
            const bar = document.getElementById('playerProgressBar');
            const rect = bar.getBoundingClientRect();
            const percent = (e.clientX - rect.left) / rect.width;
            if(timer) {
                // 重置进度模拟
                clearInterval(timer);
                startProgressSimulation();
            }
        }

        // 初始化
        buildUI();
        // 模拟默认显示登录（如果未模拟登录）
        window.showLogin = () => loginOverlay.classList.add('show');
        // 暴露一些全局方法用于调试
    })();
</script>
</body>
</html>