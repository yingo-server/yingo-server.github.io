const App = (() => {

    let currentPage = 'home';
    let loginTab = 0;
    let cdTimer = null;
    let cdNum = 0;
    let qrTimer = null;
    let qrKey = null;

    // ---- 播放器 ----
    const audio = new Audio();
    let playlist = [];
    let playIndex = -1;
    let playMode = 0;
    let isPlaying = false;
    let progTimer = null;
    let lyrics = [];
    let lyricIdx = -1;
    let lyricPage = null;
    let plPage = 1;
    let plMaxPage = 1;
    let plListid = null;
    let isLoadingMore = false;

    // ==================== TOAST ====================
    let toastEl = null;
    let toastTmr = null;
    function toast(msg, dur = 2000) {
        if (!toastEl) {
            toastEl = Util.create('div', { class: 'toast', id: 'toastEl' });
            document.body.append(toastEl);
        }
        toastEl.textContent = msg;
        toastEl.classList.add('show');
        clearTimeout(toastTmr);
        toastTmr = setTimeout(() => toastEl.classList.remove('show'), dur);
    }

    // ==================== 构建界面 ====================
    function buildShell() {
        const app = Util.$('#app');
        app.innerHTML = '';

        // 主内容
        const main = Util.create('div', { id: 'mainContent' });
        main.append(
            Util.create('div', { class: 'page active', id: 'homePage' }),
            Util.create('div', { class: 'page', id: 'myPage' }),
            Util.create('div', { class: 'page', id: 'playlistPreviewPage' }),
            Util.create('div', { class: 'search-page', id: 'searchPage' })
        );
        app.append(main);

        // 底栏
        const tab = Util.create('div', { class: 'tabbar' });
        tab.append( tabItem('home','首页','<svg viewBox="0 0 24 24"><polygon points="12,2 2,10 6,10 6,21 10,21 10,14 14,14 14,21 18,21 18,10 22,10"/></svg>') );
        tab.append( tabItem('my','我的','<svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 22c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>') );
        app.append(tab);

        // 迷你播放栏
        buildMinibar(app);

        // 全屏播放器
        buildFullPlayer(app);

        // 搜索页
        buildSearchPage();

        // 登录
        buildLogin(app);

        // 首页
        buildHomePage();

        bindTab();
    }

    function tabItem(page, label, icon) {
        const el = Util.create('div', { class: 'tabbar-item', 'data-page': page });
        el.innerHTML = `<span class="tab-icon">${icon}</span><span>${label}</span>`;
        return el;
    }

    function bindTab() {
        Util.$$('.tabbar-item').forEach(t => {
            t.addEventListener('click', () => switchPage(t.dataset.page));
        });
    }

    function switchPage(page) {
        if (page === currentPage) return;
        currentPage = page;
        Util.$$('.tabbar-item').forEach(t => t.classList.toggle('active', t.dataset.page === page));
        Util.$$('#mainContent > .page').forEach(p => p.classList.toggle('active', p.id === page + 'Page'));
        if (page === 'my') loadMyPage();
        else if (page === 'home') loadHome();
    }

    // ==================== 首页 ====================
    function buildHomePage() {
        const hp = Util.$('#homePage');
        hp.innerHTML = '';

        const sb = Util.create('div', { class: 'home-search-bar', onclick: () => { Util.$('#searchPage').classList.add('show'); setTimeout(() => Util.$('#searchInput').focus(), 150); } });
        sb.innerHTML = '<span class="search-icon"><svg viewBox="0 0 24 24"><circle cx="10" cy="10" r="7"/><line x1="16" y1="16" x2="21" y2="21"/></svg></span><span>搜索音乐</span>';
        hp.append(sb);

        hp.append(Util.create('div', { class: 'section', innerHTML: '<div class="section-title">每日推荐</div><div class="scroll-h" id="dailyScroll"></div>' }));
        hp.append(Util.create('div', { class: 'section', innerHTML: '<div class="section-title">猜你喜欢</div><div class="song-list-v" id="fmList"></div>' }));
        hp.append(Util.create('div', { class: 'section', innerHTML: '<div class="section-title">新歌速递</div><div class="song-list-v" id="hotList"></div>' }));
    }

    async function loadHome() {
        loadDaily();
        loadFM();
        loadHot();
    }

    async function loadDaily() {
        const el = Util.$('#dailyScroll');
        if (!el) return;
        el.innerHTML = '<span style="color:var(--text-hint);padding:20px;">加载中...</span>';
        const res = await Net.get('/everyday/recommend', { platform: 'ios' });
        const songs = (res.data && res.data.song_list) || [];
        if (!songs.length) { el.innerHTML = '<span style="color:var(--text-hint);padding:20px;">暂无推荐</span>'; return; }
        el.innerHTML = '';
        songs.forEach(s => {
            const c = Util.create('div', { class: 'song-card-h', onclick: () => loadPlaylist(songs, songs.indexOf(s)) });
            c.innerHTML = `<div class="card-cover">${Util.coverUrl(s) ? `<img src="${Util.coverUrl(s)}">` : '---'}</div><div class="card-name">${s.songname||'未知'}</div><div class="card-author">${s.author_name||''}</div>`;
            el.append(c);
        });
    }

    async function loadFM() {
        const el = Util.$('#fmList');
        if (!el) return;
        el.innerHTML = '<span style="color:var(--text-hint);padding:20px;">加载中...</span>';
        const res = await Net.get('/personal/fm', { mode: 'normal' });
        const songs = (res.data && res.data.song_list) || [];
        renderSongList(el, songs, '暂无推荐');
    }

    async function loadHot() {
        const el = Util.$('#hotList');
        if (!el) return;
        el.innerHTML = '<span style="color:var(--text-hint);padding:20px;">加载中...</span>';
        const res = await Net.get('/top/song');
        const songs = (res.data || []).slice(0, 20);
        renderSongList(el, songs, '暂无新歌');
    }

    function renderSongList(container, songs, emptyText = '暂无数据') {
        if (!songs.length) { container.innerHTML = `<span style="color:var(--text-hint);padding:20px;">${emptyText}</span>`; return; }
        container.innerHTML = '';
        songs.forEach((s, i) => {
            const it = Util.create('div', { class: 'song-item-v', onclick: () => loadPlaylist(songs, i) });
            it.innerHTML = `<div class="item-index">${i+1}</div><div class="item-info"><div class="item-name">${s.songname||s.SongName||'未知'}</div><div class="item-author">${s.author_name||s.SingerName||''}</div></div>`;
            container.append(it);
        });
    }

    // ==================== 搜索 ====================
    function buildSearchPage() {
        const sp = Util.$('#searchPage');
        sp.innerHTML = '';
        const top = Util.create('div', { class: 'search-top' });
        const wrap = Util.create('div', { class: 'search-input-wrap' });
        const inp = Util.create('input', { id: 'searchInput', type: 'text', placeholder: '搜索音乐、歌手、歌词' });
        inp.addEventListener('input', Util.debounce(async () => {
            const kw = inp.value.trim();
            const resEl = Util.$('#searchResults');
            if (!kw) { resEl.innerHTML = ''; return; }
            resEl.innerHTML = '<span style="color:var(--text-hint);padding:20px;">搜索中...</span>';
            const res = await Net.get('/search', { keywords: kw, type: 'song', page: 1, pagesize: 20 });
            const songs = (res.data && res.data.lists) || [];
            renderSongList(resEl, songs, '未找到结果');
        }, 400));
        wrap.append(inp);
        top.append(wrap, Util.create('span', { class: 'search-cancel', onclick: () => { sp.classList.remove('show'); inp.value = ''; Util.$('#searchResults').innerHTML = ''; } }, ['取消']));
        sp.append(top, Util.create('div', { class: 'search-results song-list-v', id: 'searchResults' }));
    }

    // ==================== 我的页面 ====================
    async function loadMyPage() {
        if (!Net.isLogin()) { showLogin(); return; }
        const mp = Util.$('#myPage');
        mp.innerHTML = '<div style="padding:40px;text-align:center;color:var(--text-hint);">加载中...</div>';

        const [detailRes, vipRes, plRes] = await Promise.all([
            Net.get('/user/detail'),
            Net.get('/user/vip/detail'),
            Net.get('/user/playlist')
        ]);

        const u = (detailRes.data) || {};
        const v = (vipRes.data) || {};
        const auth = Net.getAuth();
        const pls = (plRes.data && plRes.data.info) || [];

        const isVip = v.is_vip || u.is_vip || 0;
        const vipEnd = v.vip_end_time || u.vip_end_time || '';
        const svipLevel = v.svip_level || 0;

        mp.innerHTML = '';
        const header = Util.create('div', { class: 'my-header' });
        header.innerHTML = `
            <div class="my-avatar">${(u.pic||auth.pic) ? `<img src="${Util.imgUrl(u.pic||auth.pic,120)}">` : '---'}</div>
            <div class="my-info">
                <div class="my-nickname">${u.nickname||auth.nickname||'用户'}</div>
                <div class="my-meta">关注 ${u.follows||0}  |  粉丝 ${u.fans||0}</div>
                ${isVip ? `<div class="my-vip-badge">VIP${svipLevel?' (Lv.'+svipLevel+')':''}</div>` : ''}
            </div>`;
        mp.append(header);

        // 详细信息（不含注册时间）
        const detailWrap = Util.create('div', { class: 'my-detail-wrap' });
        const toggle = Util.create('div', { class: 'my-detail-toggle', id: 'detailToggle', innerHTML: '详细信息 <svg viewBox="0 0 24 24"><polyline points="6,9 12,15 18,9"/></svg>' });
        const content = Util.create('div', { class: 'my-detail-content', id: 'detailContent' });
        [
            ['所在地', u.loc||u.province||'未知'],
            ['性别', u.gender===1?'男':u.gender===2?'女':'未设置'],
            ['简介', u.descri||'无'],
            ['VIP到期', vipEnd || '未开通'],
            ['概念VIP', v.busi_vip && v.busi_vip.length ? (v.busi_vip[0].is_vip?'已开通':'未开通') : '--']
        ].forEach(([l, val]) => {
            content.append(Util.create('div', { class: 'detail-row', innerHTML: `<span class="detail-label">${l}</span><span class="detail-value">${val}</span>` }));
        });
        toggle.addEventListener('click', () => {
            content.classList.toggle('show');
            toggle.classList.toggle('expanded');
        });
        detailWrap.append(toggle, content);
        mp.append(detailWrap);

        // 歌单
        const plCont = Util.create('div', { class: 'my-playlist' });
        plCont.append(Util.create('div', { class: 'section-title', style: 'padding-top:8px' }, ['我的歌单']));
        if (!pls.length) plCont.append(Util.create('div', { style: 'padding:20px;color:var(--text-hint);text-align:center' }, ['暂无歌单']));
        else {
            pls.forEach(pl => {
                const it = Util.create('div', { class: 'my-playlist-item' });
                it.innerHTML = `<div class="my-playlist-cover">${pl.pic?`<img src="${Util.imgUrl(pl.pic,100)}">`:'---'}</div><div class="my-playlist-info"><div class="my-playlist-name">${pl.name||'未命名'}</div><div class="my-playlist-count">${pl.count||0} 首</div></div>`;
                it.addEventListener('click', () => openPlaylistPreview(pl));
                plCont.append(it);
            });
        }
        mp.append(plCont);
    }

    // ==================== 歌单预览 ====================
    async function openPlaylistPreview(pl) {
        plPage = 1;
        plMaxPage = Math.ceil((pl.count || 50) / 50);
        plListid = pl.listid;
        isLoadingMore = false;
        const pp = Util.$('#playlistPreviewPage');
        pp.innerHTML = `
            <div style="display:flex;align-items:center;padding:14px 16px;gap:12px;border-bottom:1px solid var(--border-subtle);">
                <div style="cursor:pointer;font-size:20px;color:var(--text-hint);" id="plBackBtn"><svg viewBox="0 0 24 24" width="20" height="20"><polyline points="15,4 5,12 15,20"/></svg></div>
                <div style="flex:1;font-weight:520;">${pl.name||'歌单'}</div>
                <div style="color:var(--accent);cursor:pointer;font-size:13px;" id="plPlayAllBtn">全部播放</div>
            </div>
            <div class="song-list-v" id="plSongList" style="padding-top:8px;padding-bottom:100px;"></div>
            <div id="plLoadMore" style="text-align:center;padding:14px;color:var(--text-hint);"></div>`;
        pp.classList.add('active');

        Util.$('#plBackBtn').addEventListener('click', () => {
            pp.classList.remove('active');
            switchPage('my');
        });

        Util.$('#plPlayAllBtn').addEventListener('click', async () => {
            const res = await Net.get('/playlist/track/all/new', { listid: pl.listid, page: 1, pagesize: 50 });
            const rows = (res.data && res.data.rows) || [];
            if (rows.length) {
                playlist = rows;
                playIndex = 0;
                plPage = 1;
                playSong(0);
            }
        });

        const listEl = Util.$('#plSongList');
        // 滚动加载
        listEl.addEventListener('scroll', () => {
            if (listEl.scrollHeight - listEl.scrollTop - listEl.clientHeight < 200 && !isLoadingMore && plPage < plMaxPage) {
                loadMorePlaylistSongs(listEl);
            }
        });

        await loadMorePlaylistSongs(listEl);
    }

    async function loadMorePlaylistSongs(listEl) {
        if (!listEl) listEl = Util.$('#plSongList');
        if (!listEl || isLoadingMore) return;
        isLoadingMore = true;
        Util.$('#plLoadMore').textContent = '加载中...';
        const res = await Net.get('/playlist/track/all/new', { listid: plListid, page: plPage, pagesize: 50 });
        const rows = (res.data && res.data.rows) || [];
        if (rows.length) {
            rows.forEach((s, i) => {
                const idx = (plPage - 1) * 50 + i;
                const it = Util.create('div', { class: 'song-item-v', onclick: () => {
                    playlist = [...(playlist || []), ...rows];
                    playSong((plPage - 1) * 50 + i);
                } });
                it.innerHTML = `<div class="item-index">${idx+1}</div><div class="item-info"><div class="item-name">${s.name||s.songname||'未知'}</div><div class="item-author">${s.author_name||s.SingerName||''}</div></div>`;
                listEl.append(it);
            });
            plPage++;
        }
        Util.$('#plLoadMore').textContent = plPage >= plMaxPage ? '已加载全部' : '上滑加载更多';
        isLoadingMore = false;
    }

    // ==================== 播放器 ====================
    function buildMinibar(app) {
        const mb = Util.create('div', { class: 'minibar', id: 'minibar', onclick: () => showFullPlayer() });
        mb.innerHTML = `
            <div class="minibar-cover" id="minibarCover">---</div>
            <div class="minibar-info">
                <div class="minibar-title-wrap"><span class="minibar-title-scroll" id="minibarTitle">未在播放</span></div>
                <div class="minibar-lyric-wrap"><span class="minibar-lyric-scroll" id="minibarLyric">点击播放音乐</span></div>
            </div>
            <div class="minibar-btn" id="minibarPlayBtn"><svg viewBox="0 0 24 24"><polygon points="6,3 20,12 6,21" fill="currentColor" stroke="none"/></svg></div>`;
        app.append(mb);
        Util.$('#minibarPlayBtn').addEventListener('click', (e) => { e.stopPropagation(); togglePlay(); });
    }

    function buildFullPlayer(app) {
        const fp = Util.create('div', { class: 'player-full', id: 'playerFull' });
        fp.innerHTML = `
            <div class="player-close" id="playerClose"><svg viewBox="0 0 24 24"><polyline points="15,4 5,12 15,20"/></svg></div>
            <div class="player-upper" id="playerUpper">
                <div class="player-cover" id="playerCover">---</div>
                <div class="player-lyric-page" id="playerLyricPage"></div>
            </div>
            <div class="player-lower">
                <div class="player-progress-row">
                    <span class="player-time" id="playerTimeCur">00:00</span>
                    <div class="player-progress" id="playerProgressBar"><div class="player-progress-fill" id="playerProgressFill"></div></div>
                    <span class="player-time" id="playerTimeTotal">00:00</span>
                </div>
                <div class="player-controls">
                    <div class="player-ctrl-btn player-mode-btn" id="playerModeBtn"><svg viewBox="0 0 24 24" width="20" height="20"><polyline points="4,4 4,16 8,16"/><polyline points="8,8 20,8 20,20 8,20 8,16"/></svg></div>
                    <div class="player-ctrl-btn" id="playerPrevBtn"><svg viewBox="0 0 24 24" width="28" height="28"><polygon points="20,3 8,12 20,21"/><rect x="2" y="3" width="4" height="18"/></svg></div>
                    <div class="player-ctrl-btn main-play" id="playerMainPlay"><svg viewBox="0 0 24 24" width="36" height="36"><polygon points="5,2 22,12 5,22" fill="currentColor" stroke="none"/></svg></div>
                    <div class="player-ctrl-btn" id="playerNextBtn"><svg viewBox="0 0 24 24" width="28" height="28"><polygon points="4,3 16,12 4,21"/><rect x="18" y="3" width="4" height="18"/></svg></div>
                    <div class="player-ctrl-btn" id="playerListBtn"><svg viewBox="0 0 24 24" width="22" height="22"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg></div>
                </div>
            </div>
            <div class="playlist-overlay" id="playlistOverlay">
                <div class="playlist-panel" id="playlistPanel"></div>
            </div>`;
        app.append(fp);

        Util.$('#playerClose').addEventListener('click', hideFullPlayer);
        Util.$('#playerModeBtn').addEventListener('click', cycleMode);
        Util.$('#playerPrevBtn').addEventListener('click', prevSong);
        Util.$('#playerMainPlay').addEventListener('click', togglePlay);
        Util.$('#playerNextBtn').addEventListener('click', nextSong);
        Util.$('#playerListBtn').addEventListener('click', showPlaylistPanel);
        Util.$('#playerProgressBar').addEventListener('click', seekProgress);
        Util.$('#playlistOverlay').addEventListener('click', (e) => { if (e.target.id === 'playlistOverlay') hidePlaylistPanel(); });

        // 手势切换歌词
        let tsY = 0;
        const upper = Util.$('#playerUpper');
        upper.addEventListener('touchstart', (e) => { tsY = e.changedTouches[0].clientY; });
        upper.addEventListener('touchend', (e) => {
            const dy = tsY - e.changedTouches[0].clientY;
            if (dy > 60) { Util.$('#playerCover').style.display = 'none'; Util.$('#playerLyricPage').classList.add('show'); }
            else if (dy < -60) { Util.$('#playerCover').style.display = ''; Util.$('#playerLyricPage').classList.remove('show'); }
        });

        lyricPage = Util.$('#playerLyricPage');
    }

    function loadPlaylist(songs, idx) {
        playlist = songs;
        playSong(idx);
    }

    async function playSong(idx) {
        if (idx < 0 || idx >= playlist.length) return;
        playIndex = idx;
        const song = playlist[idx];
        const hash = song.hash || song.FileHash || (song.HQ && song.HQ.Hash) || song.hash_320 || song.hash_128 || '';
        if (!hash) { toast('缺少歌曲标识'); return; }

        // 获取 URL
        let res = await Net.get('/song/url', { hash, quality: '320' });
        let url = Net.extractUrl(res);
        if (!url) {
            res = await Net.get('/song/url', { hash, quality: '128' });
            url = Net.extractUrl(res);
        }
        if (!url) { toast('无法获取播放地址'); console.error(res); return; }

        audio.crossOrigin = null;
        audio.src = url;
        audio.play().then(() => {
            isPlaying = true;
            updatePlayBtns();
            updateMinibarUI(song);
            updateCoverUI(song);
            startProgress();
            loadLyric(hash);
        }).catch(err => {
            toast('播放失败: ' + (err.message || ''));
        });

        // 播到倒数第二首时，如果是歌单内，自动翻页追加
        if (plListid && idx >= playlist.length - 2 && plPage <= plMaxPage && !isLoadingMore) {
            const res2 = await Net.get('/playlist/track/all/new', { listid: plListid, page: plPage, pagesize: 50 });
            const rows = (res2.data && res2.data.rows) || [];
            if (rows.length) {
                playlist.push(...rows);
                plPage++;
            }
        }
    }

    function togglePlay() {
        if (!audio.src) return;
        if (isPlaying) { audio.pause(); isPlaying = false; stopProgress(); }
        else { audio.play().then(() => { isPlaying = true; startProgress(); }).catch(() => {}); }
        updatePlayBtns();
    }

    function prevSong() {
        if (!playlist.length) return;
        let idx = playMode === 2 ? Math.floor(Math.random() * playlist.length) : playIndex - 1;
        if (idx < 0) idx = playlist.length - 1;
        playSong(idx);
    }

    function nextSong() {
        if (!playlist.length) return;
        let idx = playMode === 2 ? Math.floor(Math.random() * playlist.length) : playIndex + 1;
        if (idx >= playlist.length) idx = 0;
        playSong(idx);
    }

    function cycleMode() {
        playMode = (playMode + 1) % 3;
        Util.$('#playerModeBtn').classList.toggle('active', playMode !== 0);
    }

    function updatePlayBtns() {
        const playIcon = '<svg viewBox="0 0 24 24"><polygon points="6,3 20,12 6,21" fill="currentColor" stroke="none"/></svg>';
        const pauseIcon = '<svg viewBox="0 0 24 24"><rect x="5" y="3" width="5" height="18" fill="currentColor" stroke="none"/><rect x="14" y="3" width="5" height="18" fill="currentColor" stroke="none"/></svg>';
        Util.$('#minibarPlayBtn').innerHTML = isPlaying ? pauseIcon : playIcon;
        Util.$('#playerMainPlay').innerHTML = isPlaying
            ? '<svg viewBox="0 0 24 24" width="36" height="36"><rect x="5" y="3" width="5" height="18" fill="currentColor" stroke="none"/><rect x="14" y="3" width="5" height="18" fill="currentColor" stroke="none"/></svg>'
            : '<svg viewBox="0 0 24 24" width="36" height="36"><polygon points="5,2 22,12 5,22" fill="currentColor" stroke="none"/></svg>';
    }

    function updateMinibarUI(song) {
        const name = song.songname || song.name || song.SongName || '未知';
        const author = song.author_name || song.author || song.SingerName || '';
        Util.$('#minibarTitle').textContent = name + (author ? ' - ' + author : '');
        const cover = Util.coverUrl(song);
        Util.$('#minibarCover').innerHTML = cover ? `<img src="${cover}" onerror="this.parentElement.innerHTML='---'">` : '---';
    }

    function updateCoverUI(song) {
        const cover = Util.coverUrl(song);
        Util.$('#playerCover').innerHTML = cover ? `<img src="${cover}" onerror="this.parentElement.innerHTML='---'">` : '---';
    }

    function startProgress() {
        stopProgress();
        progTimer = setInterval(() => {
            if (!audio.duration) return;
            const cur = audio.currentTime;
            Util.$('#playerTimeCur').textContent = Util.formatTime(cur);
            Util.$('#playerTimeTotal').textContent = Util.formatTime(audio.duration);
            Util.$('#playerProgressFill').style.width = (cur / audio.duration * 100) + '%';
            updateLyricHighlight(cur);
        }, 200);
    }

    function stopProgress() { if (progTimer) clearInterval(progTimer); progTimer = null; }

    function seekProgress(e) {
        const bar = Util.$('#playerProgressBar');
        const rect = bar.getBoundingClientRect();
        audio.currentTime = audio.duration * ((e.clientX - rect.left) / rect.width);
    }

    function showFullPlayer() { Util.$('#playerFull').classList.add('show'); }
    function hideFullPlayer() { Util.$('#playerFull').classList.remove('show'); hidePlaylistPanel(); }

    function showPlaylistPanel() {
        const panel = Util.$('#playlistPanel');
        panel.innerHTML = '';
        playlist.forEach((s, i) => {
            const name = s.songname || s.name || s.SongName || '未知';
            const author = s.author_name || s.author || s.SingerName || '';
            const it = Util.create('div', { class: 'playlist-item' + (i === playIndex ? ' current' : ''), onclick: () => { playSong(i); hidePlaylistPanel(); } });
            it.innerHTML = `<div class="playlist-item-index">${i+1}</div><div class="playlist-item-info"><div class="playlist-item-name">${name}</div><div class="playlist-item-author">${author}</div></div>`;
            panel.append(it);
        });
        Util.$('#playlistOverlay').classList.add('show');
    }

    function hidePlaylistPanel() { Util.$('#playlistOverlay').classList.remove('show'); }

    // ---- 歌词 ----
    async function loadLyric(hash) {
        lyrics = [];
        lyricIdx = -1;
        if (lyricPage) lyricPage.innerHTML = '';
        let candidates = [];
        let res = await Net.get('/search/lyric', { hash });
        candidates = (res.data && res.data.candidates) || [];
        if (!candidates.length) {
            const s = playlist[playIndex];
            if (s) {
                res = await Net.get('/search/lyric', { keywords: s.songname || s.name || '' });
                candidates = (res.data && res.data.candidates) || [];
            }
        }
        if (!candidates.length) return;
        const { id, accesskey } = candidates[0];
        if (!id || !accesskey) return;
        res = await Net.get('/lyric', { id, accesskey, fmt: 'lrc', decode: 'true' });
        const content = (res.data && res.data.content) || '';
        if (!content) return;
        lyrics = parseLRC(content);
        renderLyrics();
    }

    function parseLRC(lrc) {
        const result = [];
        const re = /\[(\d{2}):(\d{2})(?:\.(\d{2,3}))?\]/g;
        lrc.split('\n').forEach(line => {
            const m = line.match(re);
            if (!m) return;
            const text = line.replace(re, '').trim();
            if (!text) return;
            m.forEach(mm => {
                const p = mm.match(/\[(\d{2}):(\d{2})(?:\.(\d{2,3}))?\]/);
                if (p) result.push({ time: parseInt(p[1])*60 + parseInt(p[2]) + (p[3] ? parseInt(p[3].padEnd(3,'0'))/1000 : 0), text });
            });
        });
        result.sort((a,b) => a.time - b.time);
        return result;
    }

    function renderLyrics() {
        if (!lyricPage) return;
        lyricPage.innerHTML = '';
        lyrics.forEach((l, i) => lyricPage.append(Util.create('div', { class: 'lyric-line', 'data-idx': i }, [l.text])));
    }

    function updateLyricHighlight(cur) {
        if (!lyrics.length) return;
        let idx = -1;
        for (let i = 0; i < lyrics.length; i++) { if (lyrics[i].time <= cur) idx = i; else break; }
        if (idx !== lyricIdx) {
            if (lyricPage) Util.$$('.lyric-line', lyricPage).forEach((l, i) => l.classList.toggle('active', i === idx));
            if (idx >= 0 && lyricPage && lyricPage.children[idx]) lyricPage.children[idx].scrollIntoView({ behavior: 'smooth', block: 'center' });
            lyricIdx = idx;
            if (idx >= 0) Util.$('#minibarLyric').textContent = lyrics[idx].text;
        }
    }

    // ==================== 登录 ====================
    function buildLogin(app) {
        const overlay = Util.create('div', { class: 'login-overlay', id: 'loginOverlay' });
        overlay.innerHTML = `
            <div class="login-dialog">
                <div class="login-tabs">
                    <span class="login-tab active" data-idx="0">验证码登录</span>
                    <span class="login-tab" data-idx="1">扫码登录</span>
                    <span class="login-tab" data-idx="2">密码登录</span>
                    <div class="login-tab-slider" id="loginTabSlider"></div>
                </div>
                <div style="position:relative;min-height:200px;">
                    <div data-panel="0" style="display:flex;flex-direction:column;gap:14px;">
                        <input class="login-input" id="loginMobileInput" type="tel" placeholder="手机号" maxlength="11" autocomplete="off">
                        <input class="login-input" id="loginCodeInput" type="text" placeholder="验证码" maxlength="6" autocomplete="off">
                        <div class="login-send-btn" id="loginSendBtn">获取验证码</div>
                    </div>
                    <div data-panel="1" style="display:none;justify-content:center;">
                        <div class="login-qr" id="loginQrBox">二维码区域<br>请使用酷狗概念版扫码</div>
                    </div>
                    <div data-panel="2" style="display:none;flex-direction:column;gap:14px;">
                        <input class="login-input" id="loginUserInput" type="text" placeholder="手机号 / 用户名" autocomplete="off">
                        <input class="login-input" id="loginPassInput" type="password" placeholder="密码" autocomplete="off">
                    </div>
                </div>
                <button class="login-submit" id="loginSubmitBtn">登 录</button>
            </div>`;
        app.append(overlay);

        Util.$$('.login-tab', overlay).forEach((t, i) => t.addEventListener('click', () => switchLoginTab(i)));
        Util.$('#loginSendBtn').addEventListener('click', sendCode);
        Util.$('#loginSubmitBtn').addEventListener('click', handleLogin);
        requestAnimationFrame(() => updateLoginSlider(false));
    }

    function switchLoginTab(idx) {
        loginTab = idx;
        const ov = Util.$('#loginOverlay');
        Util.$$('.login-tab', ov).forEach((t, i) => t.classList.toggle('active', i === idx));
        Util.$$('[data-panel]', ov).forEach(p => p.style.display = parseInt(p.dataset.panel) === idx ? 'flex' : 'none');
        updateLoginSlider();
        if (idx === 1) startQR();
        else stopQR();
    }

    function updateLoginSlider(anim = true) {
        const slider = Util.$('#loginTabSlider');
        const tab = Util.$$('.login-tab')[loginTab];
        if (!slider || !tab) return;
        if (!anim) slider.style.transition = 'none';
        else slider.style.transition = '';
        slider.style.left = (tab.offsetLeft) + 'px';
        slider.style.width = tab.offsetWidth + 'px';
        if (!anim) { void slider.offsetHeight; slider.style.transition = ''; }
    }

    async function sendCode() {
        const mobile = Util.$('#loginMobileInput').value.trim();
        if (mobile.length !== 11) { toast('请输入11位手机号码'); return; }
        const res = await Net.get('/captcha/sent', { mobile });
        if (Net.ok(res)) { toast('验证码已发送'); startCD(60); }
        else toast(res.message || '发送失败');
    }

    function startCD(s) {
        cdNum = s;
        const btn = Util.$('#loginSendBtn');
        btn.disabled = true;
        if (cdTimer) clearInterval(cdTimer);
        cdTimer = setInterval(() => {
            cdNum--;
            if (cdNum <= 0) { clearInterval(cdTimer); cdTimer = null; btn.disabled = false; btn.textContent = '获取验证码'; }
            else btn.textContent = cdNum + 's';
        }, 1000);
    }

    async function handleLogin() {
        if (loginTab === 0) {
            const m = Util.$('#loginMobileInput').value.trim();
            const c = Util.$('#loginCodeInput').value.trim();
            if (!m || !c) { toast('请填写完整'); return; }
            const res = await Net.get('/login/cellphone', { mobile: m, code: c });
            if (Net.ok(res)) { Net.saveAuth(res.data); Net.get('/register/dev').then(r => { if (r.data && r.data.dfid) Net.saveDfid(r.data.dfid); }); toast('登录成功'); hideLogin(); switchPage('home'); loadHome(); }
            else toast(res.message || '登录失败');
        } else if (loginTab === 2) {
            const u = Util.$('#loginUserInput').value.trim();
            const p = Util.$('#loginPassInput').value;
            if (!u || !p) { toast('请填写完整'); return; }
            const res = await Net.get('/login', { username: u, password: encodeURIComponent(p) });
            if (Net.ok(res)) { Net.saveAuth(res.data); Net.get('/register/dev').then(r => { if (r.data && r.data.dfid) Net.saveDfid(r.data.dfid); }); toast('登录成功'); hideLogin(); switchPage('home'); loadHome(); }
            else toast(res.message || '登录失败');
        }
    }

    async function startQR() {
        stopQR();
        const kr = await Net.get('/login/qr/key');
        if (!kr.data || !kr.data.key) { Util.$('#loginQrBox').textContent = '二维码获取失败'; return; }
        qrKey = kr.data.key;
        const qr = await Net.get('/login/qr/create', { key: qrKey, qrimg: 1 });
        if (qr.data && qr.data.qrimg) {
            Util.$('#loginQrBox').innerHTML = `<img src="${qr.data.qrimg}" alt="二维码">`;
        } else { Util.$('#loginQrBox').textContent = '二维码生成失败'; }
        qrTimer = setInterval(async () => {
            const c = await Net.get('/login/qr/check', { key: qrKey });
            const s = c.data ? c.data.status : c.status;
            if (s === 4) { stopQR(); if (c.data && c.data.token) Net.saveAuth(c.data); Net.get('/register/dev').then(r => { if (r.data && r.data.dfid) Net.saveDfid(r.data.dfid); }); toast('扫码登录成功'); hideLogin(); switchPage('home'); loadHome(); }
            else if (s === 0) { Util.$('#loginQrBox').textContent = '二维码已过期'; stopQR(); }
            else if (s === 2) { Util.$('#loginQrBox').innerHTML = '<span style="color:var(--accent)">已扫码，请确认</span>'; }
        }, 2000);
    }

    function stopQR() { if (qrTimer) clearInterval(qrTimer); qrTimer = null; qrKey = null; }
    function showLogin() { Util.$('#loginOverlay').classList.add('show'); Net.get('/register/dev').then(r => { if (r.data && r.data.dfid) Net.saveDfid(r.data.dfid); }); }
    function hideLogin() { Util.$('#loginOverlay').classList.remove('show'); stopQR(); if (cdTimer) clearInterval(cdTimer); }

    // ==================== 启动 ====================
    function init() {
        buildShell();
        switchPage('home');
        loadHome();
        if (!Net.isLogin()) setTimeout(() => showLogin(), 400);
    }

    return { init, toast, switchPage, onLoginSuccess: () => { switchPage('home'); loadHome(); } };

})();

document.addEventListener('DOMContentLoaded', () => App.init());