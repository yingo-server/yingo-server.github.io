'use strict';

const Net = (() => {
    const BASE = 'https://kapi.344977.xyz';

    function authStr() {
        const a = Tool.storage.get('auth');
        const d = Tool.storage.get('dfid') || '';
        if (!a || !a.token) return '';
        return `token=${a.token};userid=${a.userid||''};dfid=${d}`;
    }

    async function get(path, params = {}) {
        const c = authStr();
        const all = { ...params, timestamp: Date.now() };
        if (c) all.cookie = c;

        const u = new URL(path, BASE);
        Object.entries(all).forEach(([k,v]) => { if (v !== undefined && v !== null && v !== '') u.searchParams.set(k, String(v)); });

        const h = {
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
        };

        try {
            const r = await fetch(u.toString(), { method: 'GET', credentials: 'include', headers: h });
            const j = await r.json();
            return j;
        } catch(e) {
            console.error('[Net]', path, e);
            return { status: 0, error_code: -1 };
        }
    }

    function ok(res) { return res && res.status === 1 && res.error_code === 0; }

    function extractUrl(res) {
        if (!ok(res) || !res.data) return '';
        const d = res.data;
        if (d.url) {
            if (typeof d.url === 'string') return d.url;
            if (Array.isArray(d.url) && d.url.length) return d.url[0];
        }
        if (d.backupUrl && Array.isArray(d.backupUrl) && d.backupUrl.length) return d.backupUrl[0];
        if (Array.isArray(res.data) && res.data.length > 0) {
            const first = res.data[0];
            if (first && first.info && first.info.tracker_url && first.info.tracker_url.length) {
                return first.info.tracker_url[0];
            }
        }
        return '';
    }

    function saveDfid(dfid) { if (dfid) Tool.storage.set('dfid', dfid); }
    function saveAuth(d) { Tool.storage.set('auth', { token: d.token||'', userid: d.userid||'', nickname: d.nickname||'', pic: d.pic||'' }); }
    function clearAuth() { Tool.storage.remove('auth'); Tool.storage.remove('dfid'); }
    function isLogin() { const a = Tool.storage.get('auth'); return !!(a && a.token); }
    function getAuth() { return Tool.storage.get('auth'); }

    return { get, ok, extractUrl, saveDfid, saveAuth, clearAuth, isLogin, getAuth, BASE };
})();