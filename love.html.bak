<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>谢谢心意 · 墓碑铭谢</title>

    <!-- 权威无衬线字体：Noto Sans SC（中文） + Inter（英文） -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">

    <!-- 自动深色模式脚本：根据当前时间立即设置属性，防止闪烁 -->
    <script>
        (function() {
            const hour = new Date().getHours();
            const theme = (hour >= 6 && hour < 18) ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <style>
        :root {
            /* 浅色模式 — 白色大理石墓碑 */
            --bg: #f2ede6;
            --stone-bg: #fdfaf6;
            --stone-shadow: 0 4px 32px rgba(0, 0, 0, 0.08), 0 1px 6px rgba(0, 0, 0, 0.04);
            --stone-border: 1px solid rgba(0, 0, 0, 0.05);
            --text-primary: #2c2c2c;
            --text-secondary: #5c5c5c;
            --text-muted: #8a8a8a;
            --divider: #dcd5cc;
            --btn-bg: #2c2c2c;
            --btn-text: #fdfaf6;
            --btn-hover-bg: #1a1a1a;
            --btn-border: #2c2c2c;
            --img-border: #dcd5cc;
            --img-shadow: 0 1px 12px rgba(0, 0, 0, 0.06);
            --modal-overlay: rgba(0,0,0,0.2);
            --modal-bg: #ffffff;
            --transition: 0.7s ease;
        }

        [data-theme="dark"] {
            /* 深色模式 — 黑色花岗岩墓碑 */
            --bg: #121212;
            --stone-bg: #1c1c1c;
            --stone-shadow: 0 6px 40px rgba(0, 0, 0, 0.6), 0 1px 8px rgba(0, 0, 0, 0.3);
            --stone-border: 1px solid rgba(255, 255, 255, 0.06);
            --text-primary: #e5e3df;
            --text-secondary: #9f9d99;
            --text-muted: #6b6a66;
            --divider: #2e2e2e;
            --btn-bg: #e5e3df;
            --btn-text: #121212;
            --btn-hover-bg: #ffffff;
            --btn-border: #e5e3df;
            --img-border: #2e2e2e;
            --img-shadow: 0 2px 16px rgba(0, 0, 0, 0.4);
            --modal-overlay: rgba(0,0,0,0.6);
            --modal-bg: #1c1c1c;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg);
            font-family: 'Noto Sans SC', 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
            transition: background-color var(--transition);
        }

        /* 主墓碑卡片，电脑端与安卓采用相同居中单列方案，庄重克制 */
        .grave-card {
            background: var(--stone-bg);
            box-shadow: var(--stone-shadow);
            border: var(--stone-border);
            border-radius: 0px; /* 方而简洁，如墓碑 */
            padding: 48px 36px;
            max-width: 480px;
            width: 100%;
            text-align: center;
            transition: background var(--transition), box-shadow var(--transition), border var(--transition);
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 28px;
        }

        .text-block {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .chinese-main {
            font-family: 'Noto Sans SC', sans-serif;
            font-weight: 350;
            font-size: 2.6rem;
            letter-spacing: 0.08em;
            color: var(--text-primary);
            transition: color var(--transition);
            line-height: 1.2;
        }

        .english-sub {
            font-family: 'Inter', sans-serif;
            font-weight: 300;
            font-size: 1.15rem;
            letter-spacing: 0.04em;
            color: var(--text-secondary);
            word-break: break-word;
            overflow-wrap: break-word;
            white-space: normal;
            line-height: 1.5;
            transition: color var(--transition);
        }

        .divider-line {
            width: 40px;
            height: 1px;
            background: var(--divider);
            margin: 8px auto 4px;
            transition: background var(--transition);
        }

        .button-group {
            display: flex;
            flex-direction: row;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 8px;
        }

        .grave-btn {
            border: 2px solid var(--btn-border);
            background: var(--btn-bg);
            color: var(--btn-text);
            font-family: 'Noto Sans SC', 'Inter', sans-serif;
            font-weight: 450;
            font-size: 1rem;
            letter-spacing: 0.06em;
            padding: 12px 28px;
            cursor: pointer;
            transition: all 0.25s ease;
            border-radius: 0px;
            min-width: 100px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-transform: none;
            background-color: var(--btn-bg);
            appearance: none;
        }

        .grave-btn:hover {
            background-color: var(--btn-hover-bg);
            border-color: var(--btn-hover-bg);
            color: var(--btn-text);
            transform: scale(1.02);
        }

        .grave-btn.outline {
            background: transparent;
            color: var(--btn-bg);
            border-color: var(--btn-bg);
        }

        .grave-btn.outline:hover {
            background: var(--btn-bg);
            color: var(--btn-text);
        }

        /* 名单视图 (隐藏默认) */
        .acknowledgment-view {
            display: none;
            flex-direction: column;
            gap: 24px;
            width: 100%;
        }

        .acknowledgment-view.active {
            display: flex;
        }

        .main-view.hidden {
            display: none;
        }

        .list-container {
            background: transparent;
            text-align: left;
            max-height: 320px;
            overflow-y: auto;
            padding-right: 4px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .list-item {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            font-size: 0.95rem;
            border-bottom: 1px solid var(--divider);
            padding-bottom: 8px;
            color: var(--text-primary);
            transition: color var(--transition);
        }

        .list-name {
            font-weight: 450;
        }

        .list-time {
            font-weight: 300;
            color: var(--text-muted);
            font-family: 'Inter', sans-serif;
            letter-spacing: 0.02em;
        }

        .empty-message {
            color: var(--text-muted);
            font-style: italic;
            text-align: center;
            padding: 16px;
        }

        .back-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* 弹窗 modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--modal-overlay);
            backdrop-filter: blur(6px);
            align-items: center;
            justify-content: center;
            z-index: 1000;
            transition: opacity 0.3s ease;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: var(--modal-bg);
            border: var(--stone-border);
            box-shadow: var(--stone-shadow);
            padding: 36px 28px;
            max-width: 400px;
            width: 90%;
            border-radius: 0;
            display: flex;
            flex-direction: column;
            gap: 24px;
            text-align: center;
            transition: background var(--transition);
        }

        .modal-input {
            border: 1px solid var(--divider);
            background: var(--stone-bg);
            color: var(--text-primary);
            padding: 14px 16px;
            font-family: 'Noto Sans SC', sans-serif;
            font-size: 1rem;
            border-radius: 0;
            outline: none;
            transition: border 0.2s;
        }

        .modal-input:focus {
            border-color: var(--btn-bg);
        }

        .qr-image {
            width: 180px;
            height: 180px;
            object-fit: contain;
            margin: 0 auto;
            border: 1px solid var(--img-border);
            box-shadow: var(--img-shadow);
            transition: border var(--transition);
        }

        .modal-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
        }

        .small-note {
            color: var(--text-muted);
            font-size: 0.8rem;
            letter-spacing: 0.03em;
        }

        @media (max-width: 480px) {
            .grave-card {
                padding: 36px 24px;
            }
            .chinese-main {
                font-size: 2.2rem;
            }
        }
    </style>
</head>
<body>
    <div class="grave-card" id="mainCard">
        <!-- 主感谢视图 -->
        <div class="main-view" id="mainView">
            <div class="text-block">
                <div class="chinese-main">谢谢心意</div>
                <div class="english-sub">Thank you for your kindness.<br>Your generosity becomes a stone in this quiet garden.</div>
            </div>
            <div class="divider-line"></div>
            <div class="button-group">
                <button class="grave-btn" id="btnMingXie">铭谢</button>
                <button class="grave-btn outline" id="btnMingXieList">鸣谢</button>
            </div>
            <div class="small-note" style="margin-top: 4px;">刻下名字，或静默凝视</div>
        </div>

        <!-- 鸣谢名单视图 (默认隐藏) -->
        <div class="acknowledgment-view" id="ackView">
            <div class="back-row">
                <button class="grave-btn outline" id="btnBack" style="padding: 8px 18px; min-width: auto;">← 返回</button>
                <button class="grave-btn" id="btnMingXieInList" style="padding: 8px 18px; min-width: auto;">铭谢</button>
            </div>
            <div style="font-weight: 400; font-size: 1.2rem; color: var(--text-primary); letter-spacing: 0.05em;">鸣谢名单</div>
            <div class="list-container" id="nameListContainer">
                <div class="empty-message">石面尚空，静待第一个名字。</div>
            </div>
            <div class="small-note" style="color: var(--text-muted);">按时间倒序 · 铭刻于此</div>
        </div>
    </div>

    <!-- 输入姓名弹窗 (铭谢) -->
    <div class="modal" id="modalNameInput">
        <div class="modal-content">
            <div style="font-weight: 400; font-size: 1.3rem; color: var(--text-primary);">留下你的姓名</div>
            <input type="text" class="modal-input" id="inputName" placeholder="姓氏或名号" maxlength="30" autocomplete="off">
            <div class="modal-actions">
                <button class="grave-btn outline" id="btnCancelName">取消</button>
                <button class="grave-btn" id="btnConfirmName">铭刻</button>
            </div>
            <div class="small-note" id="nameError" style="color: #c96b6b; display: none;"></div>
        </div>
    </div>

    <!-- 铭谢成功 / 二维码展示弹窗 -->
    <div class="modal" id="modalThanks">
        <div class="modal-content">
            <div style="font-weight: 400; font-size: 1.3rem; color: var(--text-primary);" id="thanksMessage">心意已铭刻</div>
            <img src="https://181683446874112.abvod.cn/1.png" alt="捐赠二维码" class="qr-image" crossorigin="anonymous">
            <div class="small-note">请扫码传递温暖</div>
            <button class="grave-btn" id="btnCloseThanks" style="margin-top: 4px;">关闭</button>
        </div>
    </div>

    <script>
        (function() {
            // Gitee 配置
            const GITEE_CONFIG = {
                accessToken: "89b450ecbd9617ab1b1467076edf472d",
                owner: "QI403403",
                repo: "DO",
                branch: "master",
                filePath: "names/sth.json"
            };

            const API_BASE = "https://gitee.com/api/v5";

            // 通用请求头
            function getHeaders() {
                return {
                    "Authorization": `token ${GITEE_CONFIG.accessToken}`,
                    "Content-Type": "application/json",
                    "Accept": "application/json"
                };
            }

            // 工具：显示/隐藏弹窗
            function toggleModal(modalId, show) {
                const modal = document.getElementById(modalId);
                if (show) modal.classList.add('active');
                else modal.classList.remove('active');
            }

            // 检测仓库是否存在，不存在则创建
            async function ensureRepoExists() {
                const url = `${API_BASE}/repos/${GITEE_CONFIG.owner}/${GITEE_CONFIG.repo}`;
                try {
                    const resp = await fetch(url, { headers: getHeaders() });
                    if (resp.ok) {
                        console.log("仓库已存在");
                        return true;
                    }
                    if (resp.status === 404) {
                        // 创建仓库
                        const createUrl = `${API_BASE}/user/repos`;
                        const body = JSON.stringify({
                            name: GITEE_CONFIG.repo,
                            private: false,
                            auto_init: false,
                            description: "捐赠铭谢墓石"
                        });
                        const createResp = await fetch(createUrl, {
                            method: "POST",
                            headers: getHeaders(),
                            body: body
                        });
                        if (createResp.ok) {
                            console.log("仓库创建成功");
                            return true;
                        } else {
                            const err = await createResp.json();
                            console.error("创建仓库失败", err);
                            throw new Error("无法创建仓库：" + (err.message || "未知错误"));
                        }
                    } else {
                        throw new Error("检测仓库失败，状态码：" + resp.status);
                    }
                } catch (e) {
                    console.error(e);
                    throw e;
                }
            }

            // 检查文件是否存在，返回 { exists, sha, content }
            async function getFileInfo() {
                const url = `${API_BASE}/repos/${GITEE_CONFIG.owner}/${GITEE_CONFIG.repo}/contents/${GITEE_CONFIG.filePath}?ref=${GITEE_CONFIG.branch}`;
                const resp = await fetch(url, { headers: getHeaders() });
                if (resp.status === 200) {
                    const data = await resp.json();
                    return { exists: true, sha: data.sha, content: data.content, encoding: data.encoding };
                } else if (resp.status === 404) {
                    return { exists: false, sha: null, content: null };
                } else {
                    throw new Error("获取文件信息失败：" + resp.status);
                }
            }

            // 创建初始空数组文件（如果不存在）
            async function createEmptyFileIfNotExist() {
                const fileInfo = await getFileInfo();
                if (!fileInfo.exists) {
                    const url = `${API_BASE}/repos/${GITEE_CONFIG.owner}/${GITEE_CONFIG.repo}/contents/${GITEE_CONFIG.filePath}`;
                    const body = JSON.stringify({
                        access_token: GITEE_CONFIG.accessToken,
                        content: btoa(unescape(encodeURIComponent("[]"))), // 空数组
                        message: "初始化铭谢石碑",
                        branch: GITEE_CONFIG.branch
                    });
                    const resp = await fetch(url, {
                        method: "POST",
                        headers: getHeaders(),
                        body: body
                    });
                    if (!resp.ok) {
                        const err = await resp.json();
                        throw new Error("创建文件失败：" + (err.message || ""));
                    }
                    console.log("文件已初始化");
                }
            }

            // 获取当前名单数组
            async function fetchNameList() {
                const fileInfo = await getFileInfo();
                if (!fileInfo.exists) return [];
                try {
                    const decoded = atob(fileInfo.content);
                    const list = JSON.parse(decoded);
                    return Array.isArray(list) ? list : [];
                } catch (e) {
                    console.error("名单解析失败", e);
                    return [];
                }
            }

            // 追加姓名并更新文件
            async function appendNameToFile(name) {
                // 确保仓库和文件存在
                await ensureRepoExists();
                await createEmptyFileIfNotExist();

                // 获取最新文件信息和sha
                const fileInfo = await getFileInfo();
                if (!fileInfo.exists) throw new Error("文件意外不存在");

                let list = [];
                try {
                    const decoded = atob(fileInfo.content);
                    list = JSON.parse(decoded);
                    if (!Array.isArray(list)) list = [];
                } catch (e) {
                    list = [];
                }

                // 添加新条目
                const newEntry = {
                    name: name.trim(),
                    timestamp: new Date().toISOString()
                };
                list.push(newEntry);

                // 更新文件 (PUT)
                const updateUrl = `${API_BASE}/repos/${GITEE_CONFIG.owner}/${GITEE_CONFIG.repo}/contents/${GITEE_CONFIG.filePath}`;
                const newContent = btoa(unescape(encodeURIComponent(JSON.stringify(list, null, 2))));
                const body = JSON.stringify({
                    access_token: GITEE_CONFIG.accessToken,
                    content: newContent,
                    sha: fileInfo.sha,
                    message: `铭谢: ${name}`,
                    branch: GITEE_CONFIG.branch
                });

                const resp = await fetch(updateUrl, {
                    method: "PUT",
                    headers: getHeaders(),
                    body: body
                });

                if (!resp.ok) {
                    const err = await resp.json();
                    throw new Error("更新文件失败：" + (err.message || ""));
                }
                console.log("名字已铭刻");
                return newEntry;
            }

            // 渲染名单视图
            async function renderNameList() {
                const container = document.getElementById('nameListContainer');
                try {
                    const list = await fetchNameList();
                    if (list.length === 0) {
                        container.innerHTML = '<div class="empty-message">石面尚空，静待第一个名字。</div>';
                        return;
                    }
                    // 按时间倒序
                    const sorted = [...list].sort((a, b) => (b.timestamp || '').localeCompare(a.timestamp || ''));
                    let html = '';
                    sorted.forEach(entry => {
                        const timeStr = entry.timestamp ? new Date(entry.timestamp).toLocaleString('zh-CN', { hour12: false }) : '';
                        html += `<div class="list-item"><span class="list-name">${escapeHtml(entry.name)}</span><span class="list-time">${timeStr}</span></div>`;
                    });
                    container.innerHTML = html;
                } catch (e) {
                    container.innerHTML = '<div class="empty-message">无法读取名单，请稍后重试。</div>';
                    console.error(e);
                }
            }

            function escapeHtml(text) {
                return String(text).replace(/[&<>"]/g, function(m) {
                    if (m === '&') return '&amp;';
                    if (m === '<') return '&lt;';
                    if (m === '>') return '&gt;';
                    if (m === '"') return '&quot;';
                    return m;
                });
            }

            // 界面切换
            const mainView = document.getElementById('mainView');
            const ackView = document.getElementById('ackView');
            const btnMingXieList = document.getElementById('btnMingXieList');
            const btnBack = document.getElementById('btnBack');
            const btnMingXie = document.getElementById('btnMingXie');
            const btnMingXieInList = document.getElementById('btnMingXieInList');

            btnMingXieList.addEventListener('click', () => {
                mainView.classList.add('hidden');
                ackView.classList.add('active');
                renderNameList();
            });

            btnBack.addEventListener('click', () => {
                ackView.classList.remove('active');
                mainView.classList.remove('hidden');
            });

            // 铭谢按钮 (主页面和名单内)
            function openNameModal() {
                document.getElementById('inputName').value = '';
                document.getElementById('nameError').style.display = 'none';
                toggleModal('modalNameInput', true);
            }

            btnMingXie.addEventListener('click', openNameModal);
            btnMingXieInList.addEventListener('click', openNameModal);

            // 取消输入
            document.getElementById('btnCancelName').addEventListener('click', () => {
                toggleModal('modalNameInput', false);
            });

            // 确认铭刻名字
            document.getElementById('btnConfirmName').addEventListener('click', async () => {
                const nameInput = document.getElementById('inputName');
                const name = nameInput.value.trim();
                const errorDiv = document.getElementById('nameError');

                if (!name) {
                    errorDiv.textContent = '名字不可为空';
                    errorDiv.style.display = 'block';
                    return;
                }
                if (name.length > 30) {
                    errorDiv.textContent = '姓名请勿超过30个字符';
                    errorDiv.style.display = 'block';
                    return;
                }

                // 禁用按钮，显示加载状态
                const confirmBtn = document.getElementById('btnConfirmName');
                confirmBtn.disabled = true;
                confirmBtn.textContent = '铭刻中...';
                errorDiv.style.display = 'none';

                try {
                    await appendNameToFile(name);
                    // 成功后关闭输入弹窗，展示二维码弹窗
                    toggleModal('modalNameInput', false);
                    document.getElementById('thanksMessage').textContent = `「${name}」心意已铭刻`;
                    toggleModal('modalThanks', true);

                    // 如果当前在名单视图，刷新名单
                    if (ackView.classList.contains('active')) {
                        renderNameList();
                    }
                } catch (e) {
                    errorDiv.textContent = '铭刻失败：' + e.message;
                    errorDiv.style.display = 'block';
                } finally {
                    confirmBtn.disabled = false;
                    confirmBtn.textContent = '铭刻';
                }
            });

            // 关闭感谢弹窗
            document.getElementById('btnCloseThanks').addEventListener('click', () => {
                toggleModal('modalThanks', false);
            });

            // 点击模态框背景也可关闭
            window.addEventListener('click', (e) => {
                if (e.target.classList.contains('modal') && e.target.classList.contains('active')) {
                    e.target.classList.remove('active');
                }
            });

            // 初始检查仓库和文件（静默，不阻塞页面）
            (async function initCheck() {
                try {
                    await ensureRepoExists();
                    await createEmptyFileIfNotExist();
                    console.log("Gitee 仓库与文件就绪");
                } catch (e) {
                    console.warn("初始化仓库检查未通过，将在操作时重试", e);
                }
            })();

            // 监听深色模式变化：如果系统时间跨越6点/18点，页面不会自动刷新，但重新加载时生效。
            // 这里可以增加一个定时器，每30分钟检查一次并切换主题（无需刷新）
            setInterval(() => {
                const hour = new Date().getHours();
                const currentTheme = document.documentElement.getAttribute('data-theme');
                const expectedTheme = (hour >= 6 && hour < 18) ? 'light' : 'dark';
                if (currentTheme !== expectedTheme) {
                    document.documentElement.setAttribute('data-theme', expectedTheme);
                }
            }, 1800000); // 30分钟检测一次
        })();
    </script>
</body>
</html>